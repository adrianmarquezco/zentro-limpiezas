---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import WhatsAppFloat from '@/components/ui/WhatsAppFloat.astro';
import { BUSINESS, buildWhatsAppUrl, WA_MESSAGES } from '@/data/config';
import { SERVICIOS } from '@/data/servicios';

const canonical = `${BUSINESS.url}/presupuesto/`;
const title = 'Presupuesto limpieza en Ferrol y A Coruña | Zentro Limpiezas';
const description = 'Presupuesto gratis de limpieza de viviendas, oficinas y locales en Ferrol, Narón y A Coruña. Precios desde 55€. Te respondemos en menos de 24 horas.';

const breadcrumbs = [
  { label: 'Presupuesto', href: '/presupuesto/' },
];

const waUrl = buildWhatsAppUrl(WA_MESSAGES.presupuesto);
---

<BaseLayout {title} {description} {canonical} lang="es" hreflangEs={canonical} hreflangGl={`${BUSINESS.url}/gl/orzamento/`}>
  <Breadcrumbs crumbs={breadcrumbs} dark={true} />

  <section class="hero-section bg-primary py-16 relative">
    <div class="noise-overlay" />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-serif text-4xl lg:text-5xl text-warm mb-4" data-reveal>
        Pide presupuesto de limpieza<br><span class="text-accent">en Ferrol y A Coruña</span>
      </h1>
      <p class="text-white/70 text-lg max-w-xl mx-auto" data-reveal>
        Sin compromiso. Te respondemos en menos de 24 horas.
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-warm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-start">

        <!-- Formulario -->
        <div>
          <h2 class="font-display text-2xl text-primary mb-6" data-reveal>Cuéntanos qué necesitas</h2>
          <form
            id="presupuesto-form"
            action="/api/presupuesto"
            method="POST"
            class="space-y-4 bg-white rounded-2xl border border-line p-6 lg:p-8 shadow-sm"
            data-reveal
            novalidate
          >
            <div>
              <label for="nombre" class="form-label">Tu nombre *</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                autocomplete="name"
                placeholder="María García"
                class="form-field"
              />
            </div>

            <div>
              <span class="form-label block mb-2">¿Cómo prefieres que te contactemos? *</span>
              <div class="grid grid-cols-3 gap-2">
                <label class="cursor-pointer">
                  <input type="radio" name="contacto_preferido" value="whatsapp" required class="sr-only peer" />
                  <span class="flex flex-col items-center gap-1.5 p-3 rounded-xl border-2 border-line bg-white text-xs font-semibold text-mid peer-checked:border-accent peer-checked:bg-accent/5 peer-checked:text-primary transition-all hover:border-primary/30">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-success"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                    WhatsApp
                  </span>
                </label>
                <label class="cursor-pointer">
                  <input type="radio" name="contacto_preferido" value="llamada" class="sr-only peer" />
                  <span class="flex flex-col items-center gap-1.5 p-3 rounded-xl border-2 border-line bg-white text-xs font-semibold text-mid peer-checked:border-accent peer-checked:bg-accent/5 peer-checked:text-primary transition-all hover:border-primary/30">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.65 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    Llamada
                  </span>
                </label>
                <label class="cursor-pointer">
                  <input type="radio" name="contacto_preferido" value="email" class="sr-only peer" />
                  <span class="flex flex-col items-center gap-1.5 p-3 rounded-xl border-2 border-line bg-white text-xs font-semibold text-mid peer-checked:border-accent peer-checked:bg-accent/5 peer-checked:text-primary transition-all hover:border-primary/30">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    Email
                  </span>
                </label>
              </div>
            </div>

            <div>
              <label for="telefono" class="form-label">Teléfono <span class="text-mid font-normal">(para WhatsApp o llamada)</span></label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                autocomplete="tel"
                placeholder="666 123 456"
                class="form-field"
              />
            </div>

            <div>
              <label for="email" class="form-label">Email <span class="text-mid font-normal">(opcional)</span></label>
              <input
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                placeholder="maria@ejemplo.com"
                class="form-field"
              />
            </div>

            <div>
              <label for="servicio" class="form-label">Servicio que necesitas *</label>
              <select
                id="servicio"
                name="servicio"
                required
                class="form-field"
              >
                <option value="">Selecciona un servicio</option>
                {SERVICIOS.map(s => (
                  <option value={s.nombre}>{s.nombre}</option>
                ))}
                <option value="Otro">Otro / No sé</option>
              </select>
            </div>

            <div>
              <label for="zona" class="form-label">Municipio o zona *</label>
              <input
                type="text"
                id="zona"
                name="zona"
                required
                placeholder="Ferrol, A Coruña, Narón..."
                class="form-field"
              />
            </div>

            <div>
              <span class="form-label block mb-2">¿Cuándo lo necesitas?</span>
              <div class="grid grid-cols-2 gap-2">
                {[
                  { value: 'urgente',      label: 'Lo antes posible' },
                  { value: 'esta-semana',  label: 'Esta semana' },
                  { value: 'este-mes',     label: 'Este mes' },
                  { value: 'sin-fecha',    label: 'Sin fecha fija' },
                ].map(op => (
                  <label class="cursor-pointer">
                    <input type="radio" name="urgencia" value={op.value} class="sr-only peer" />
                    <span class="flex items-center justify-center p-2.5 rounded-xl border-2 border-line bg-white text-xs font-medium text-mid peer-checked:border-accent peer-checked:bg-accent/5 peer-checked:text-primary transition-all hover:border-primary/30 text-center">
                      {op.label}
                    </span>
                  </label>
                ))}
              </div>
            </div>

            <div>
              <label for="mensaje" class="form-label">Cuéntanos más (opcional)</label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="4"
                placeholder="Tamaño del piso, frecuencia, urgencia, cualquier detalle que nos ayude..."
                class="form-field resize-none"
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="privacidad"
                name="privacidad"
                required
                class="mt-1 accent-accent"
              />
              <label for="privacidad" class="text-mid text-sm">
                He leído y acepto la <a href="/legal/politica-privacidad/" class="text-accent hover:underline">política de privacidad</a> *
              </label>
            </div>

            <!-- Honeypot anti-spam -->
            <input type="text" name="_honeypot" class="hidden" tabindex="-1" autocomplete="off" />

            <button type="submit" class="btn btn-accent w-full py-4 text-base font-semibold">
              Enviar solicitud →
            </button>

            <p class="text-mid text-xs text-center">
              También puedes llamarnos al <a href={BUSINESS.phoneHref} class="text-accent">{BUSINESS.phoneDisplay}</a> o escribirnos por WhatsApp.
            </p>
          </form>

          <!-- Estados del formulario -->
          <div id="form-success" class="hidden mt-4 p-4 bg-accent/10 border border-accent/30 rounded-lg text-accent text-sm">
            ✓ Mensaje enviado. Te contactamos en menos de 24 horas.
          </div>
          <div id="form-error" class="hidden mt-4 p-4 bg-red-500/10 border border-red-500/30 rounded-lg text-red-400 text-sm">
            Algo ha fallado. Llámanos directamente al <a href={BUSINESS.phoneHref} class="underline">{BUSINESS.phoneDisplay}</a>.
          </div>
        </div>

        <!-- Alternativas + info -->
        <div class="space-y-6">

          <!-- Foto equipo -->
          <div class="rounded-2xl overflow-hidden aspect-video lg:aspect-[4/3] shadow-sm" data-reveal>
            <img
              src="/images/equipo-limpieza-oficinas.webp"
              alt="Equipo profesional de Zentro Limpiezas realizando limpieza de oficina en Ferrol"
              class="w-full h-full object-cover"
              width="800"
              height="600"
              loading="lazy"
              decoding="async"
              onerror="this.parentElement.style.display='none'"
            />
          </div>

          <div class="card p-6" data-reveal>
            <p class="font-serif text-lg text-primary mb-4 font-semibold">¿Prefieres hablar directamente?</p>
            <div class="flex flex-col gap-3">
              <a href={BUSINESS.phoneHref} class="btn btn-primary w-full flex items-center justify-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
                  <path d="M222.37,158.46l-47.11-21.11-.13-.06a16,16,0,0,0-15.17,1.4,8.12,8.12,0,0,0-.75.56L134.87,160c-15.42-7.49-31.34-23.29-38.83-38.51l20.78-24.71c.2-.25.39-.5.57-.77a16,16,0,0,0,1.32-15.06l0-.12L97.54,33.64a16,16,0,0,0-16.62-9.52A56.26,56.26,0,0,0,32,80c0,79.4,64.6,144,144,144a56.26,56.26,0,0,0,55.88-48.92A16,16,0,0,0,222.37,158.46Z"/>
                </svg>
                Llamar al {BUSINESS.phoneDisplay}
              </a>
              <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp w-full flex items-center justify-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
                  <path d="M187.58,144.84l-32-16a8,8,0,0,0-8,.5l-14.69,9.8a40.55,40.55,0,0,1-16-16l9.8-14.69a8,8,0,0,0,.5-8l-16-32A8,8,0,0,0,104,64a40,40,0,0,0-40,40,88.1,88.1,0,0,0,88,88,40,40,0,0,0,40-40A8,8,0,0,0,187.58,144.84ZM152,176a72.08,72.08,0,0,1-72-72,24,24,0,0,1,19.29-23.54l11.48,23L101,118.18a8,8,0,0,0-.73,7.51,56.47,56.47,0,0,0,30,30,8,8,0,0,0,7.53-.68l14.71-9.8,23,11.48A24,24,0,0,1,152,176ZM128,24A104,104,0,0,0,36.18,176.88L24.83,210.93a16,16,0,0,0,20.24,20.24l34.05-11.35A104,104,0,1,0,128,24Zm0,192a88.11,88.11,0,0,1-45.06-12.34,8,8,0,0,0-6.54-.67L40,216,52.95,179.6a8,8,0,0,0-.66-6.54A88,88,0,1,1,128,216Z"/>
                </svg>
                WhatsApp
              </a>
            </div>
          </div>

          <div class="card p-6" data-reveal>
            <p class="font-serif text-lg text-primary mb-4 font-semibold">¿Qué pasa después?</p>
            <ol class="space-y-4">
              {[
                { n: '1', t: 'Recibimos tu solicitud', d: 'En horario de oficina, en menos de una hora.' },
                { n: '2', t: 'Te llamamos o escribimos', d: 'Para entender mejor qué necesitas.' },
                { n: '3', t: 'Presupuesto personalizado', d: 'Claro, sin letra pequeña. Gratis.' },
                { n: '4', t: 'Fijamos fecha', d: 'A la hora que mejor te venga.' },
              ].map(step => (
                <li class="flex items-start gap-3">
                  <span class="font-mono text-accent text-sm w-5 shrink-0">{step.n}.</span>
                  <div>
                    <p class="text-charcoal text-sm font-semibold">{step.t}</p>
                    <p class="text-mid text-xs mt-0.5">{step.d}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>

          <div class="card p-6" data-reveal>
            <p class="font-serif text-base text-primary mb-3 font-semibold">Horario de atención</p>
            <ul class="space-y-2 text-sm text-charcoal">
              <li class="flex justify-between">
                <span>Lunes – Viernes</span>
                <span class="font-mono text-primary font-semibold">08:00 – 14:00</span>
              </li>
              <li class="flex justify-between">
                <span>Sábados</span>
                <span class="font-mono text-primary font-semibold">09:00 – 14:00</span>
              </li>
            </ul>
            <p class="text-mid text-xs mt-3">Los servicios se realizan también tardes y fines de semana.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <WhatsAppFloat />
</BaseLayout>

<script>
const form = document.getElementById('presupuesto-form') as HTMLFormElement;
const successEl = document.getElementById('form-success');
const errorEl = document.getElementById('form-error');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
  btn.disabled = true;
  btn.textContent = 'Enviando...';

  const data = new FormData(form);
  // Honeypot check client-side
  if (data.get('_honeypot')) return;

  try {
    const res = await fetch('/api/presupuesto', {
      method: 'POST',
      body: data,
    });
    if (res.ok) {
      form.classList.add('hidden');
      successEl?.classList.remove('hidden');
    } else {
      throw new Error('Error');
    }
  } catch {
    errorEl?.classList.remove('hidden');
    btn.disabled = false;
    btn.textContent = 'Enviar solicitud →';
  }
});
</script>

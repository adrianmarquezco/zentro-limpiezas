---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import ZoneGrid from '@/components/sections/ZoneGrid.astro';
import CTASection from '@/components/sections/CTASection.astro';
import WhatsAppFloat from '@/components/ui/WhatsAppFloat.astro';
import CTABar from '@/components/ui/CTABar.astro';
import { BUSINESS } from '@/data/config';

const canonical = `${BUSINESS.url}/zonas/`;
const title = 'Empresa de limpieza en Ferrol y A Coruña | Zentro Limpiezas';
const description = 'Servicio de limpieza profesional en Ferrol, Narón, A Coruña y más de 29 municipios de Ferrolterra y el Área Metropolitana. Sin recargo por desplazamiento.';

const breadcrumbs = [
  { label: 'Zonas', href: '/zonas/' },
];
---

<BaseLayout {title} {description} {canonical} lang="es" hreflangEs={canonical} hreflangGl={`${BUSINESS.url}/gl/zonas/`}>
  <Breadcrumbs crumbs={breadcrumbs} dark={true} />

  <section class="hero-section bg-primary py-20 lg:py-28 relative overflow-hidden">
    <div class="noise-overlay absolute inset-0 pointer-events-none" />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <h1 class="font-display text-4xl lg:text-5xl text-white mb-4" data-reveal>
        Empresa de limpieza en Ferrol, A Coruña y toda Ferrolterra
      </h1>
      <p class="text-white/70 text-lg max-w-2xl mx-auto" data-reveal>
        Cubrimos más de 29 municipios en Galicia. Desde Ferrol hasta A Coruña, pasando por toda su comarca y área metropolitana.
      </p>
    </div>
  </section>

  <ZoneGrid variant="all" showHeading={true} />

  <CTASection />
  <WhatsAppFloat />
  <CTABar />
</BaseLayout>

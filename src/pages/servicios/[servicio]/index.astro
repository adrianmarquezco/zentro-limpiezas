---
import ServiceLayout from '@/layouts/ServiceLayout.astro';
import HeroService from '@/components/sections/HeroService.astro';
import FAQAccordion from '@/components/ui/FAQAccordion.astro';
import EcoBadge from '@/components/ui/EcoBadge.astro';
import ContactStrip from '@/components/sections/ContactStrip.astro';
import { SERVICIOS } from '@/data/servicios';
import { getMunicipioBySlug } from '@/data/municipios';
import { BUSINESS } from '@/data/config';

export function getStaticPaths() {
  return SERVICIOS.map((s) => ({
    params: { servicio: s.slug },
    props: { servicio: s },
  }));
}

const { servicio } = Astro.props;
const canonical = `${BUSINESS.url}/servicios/${servicio.slug}/`;
const hreflangGl = `${BUSINESS.url}/gl/servizos/${servicio.slugGL}/`;

const title = `${servicio.nombre} en Galicia | Zentro Limpiezas`;
const description = `${servicio.descripcionCorta} Productos ecológicos incluidos. Más de 20 años de experiencia en Ferrol y A Coruña. Presupuesto gratis.`;

const breadcrumbs = [
  { label: 'Servicios', href: '/servicios/' },
  { label: servicio.nombre, href: `/servicios/${servicio.slug}/` },
];

const municipiosConCombo = servicio.municipiosCombo
  .map(slug => getMunicipioBySlug(slug))
  .filter(Boolean);

const faqs: { q: string; a: string }[] = [
  {
    q: `¿Cuánto cuesta el servicio de ${servicio.nombre.toLowerCase()}?`,
    a: servicio.precioDesde
      ? `El precio comienza desde ${servicio.precioDesde}. El presupuesto final depende del tamaño, el estado del espacio y la frecuencia. Te lo damos gratis, por teléfono o WhatsApp, sin visita obligatoria.`
      : `El precio depende del tamaño, estado y frecuencia. Te hacemos un presupuesto personalizado y gratuito en menos de 24 horas, sin compromiso ni visita obligatoria.`,
  },
  {
    q: '¿Los productos ecológicos tienen coste adicional?',
    a: 'No, en absoluto. Todos nuestros servicios incluyen productos de limpieza con certificación ecológica Ecolabel sin coste extra. Es nuestro estándar de trabajo desde hace más de 20 años, no un servicio premium.',
  },
  {
    q: '¿Con cuánta antelación hay que reservar?',
    a: 'Para servicios de mantenimiento habitual (limpieza periódica, viviendas) normalmente podemos darte cita en 24-48 horas. Para trabajos de mayor envergadura como fin de obra o pazos para eventos, recomendamos avisar con 3-5 días de antelación.',
  },
  {
    q: '¿Trabajáis fines de semana y festivos?',
    a: 'Sí. Realizamos servicios de lunes a domingo, incluyendo tardes, fines de semana y festivos según disponibilidad. Nuestro horario de atención telefónica es de lunes a viernes de 8:00 a 14:00 y sábados de 9:00 a 14:00, pero puedes escribirnos por WhatsApp cualquier día.',
  },
  {
    q: `¿En qué zonas ofrecéis ${servicio.nombre.toLowerCase()}?`,
    a: `Cubrimos Ferrol, Narón, A Coruña y más de 29 municipios de Ferrolterra y el área metropolitana coruñesa. Si tienes dudas sobre si llegamos a tu zona, llámanos al ${BUSINESS.phoneDisplay} o escríbenos por WhatsApp.`,
  },
  {
    q: '¿Traéis vosotros los materiales y productos?',
    a: 'Sí, todo incluido. Material de limpieza profesional, maquinaria si se necesita y productos ecológicos certificados. No tienes que tener nada preparado en casa. El precio del presupuesto cubre la mano de obra y los materiales completos.',
  },
];

// Contenido detallado por servicio
type ContenidoServicio = {
  intro: string;
  parrafo2: string;
  parrafo3?: string;
  incluye: string[];
  proceso: { titulo: string; desc: string }[];
  porqueNosotros: string;
  articulosRelacionados: { titulo: string; href: string }[];
};

const contenidoDetalladoMap: Record<string, ContenidoServicio> = {
  'limpieza-de-viviendas': {
    intro: `La limpieza del hogar es mucho más que pasar el aspirador y fregar el suelo. En Zentro Limpiezas llevamos más de 20 años ayudando a familias de Ferrol, A Coruña y toda Ferrolterra a tener sus hogares realmente limpios — no solo "presentables a primera vista", sino higienizados a fondo, con cada rincón tratado con la técnica y el producto correctos.`,
    parrafo2: `Nuestro servicio de limpieza de viviendas cubre todas las estancias: salón, dormitorios, cocina, baños, pasillos y zonas de paso. Limpieza de polvo en muebles y superficies, aspirado de suelos y tapicerías, fregado, desinfección de baños y cocina, y atención a los detalles que marcan la diferencia —rodapiés, interruptores, pomos de puertas, cristales interiores. Todo con productos ecológicos con certificación Ecolabel, igual de eficaces que los convencionales pero seguros para tu familia, tus mascotas y el entorno.`,
    parrafo3: `Puedes contratarnos para una limpieza puntual —antes de una visita, después de una temporada fuera, o simplemente cuando se acumula más de lo que el día a día permite— o establecer un servicio periódico semanal, quincenal o mensual. En el servicio periódico, siempre viene el mismo equipo: ya conocen tu casa y saben cómo la quieres sin que tengas que explicar nada cada vez.`,
    incluye: [
      'Aspirado completo de suelos, moquetas y tapicerías',
      'Fregado de suelos con producto ecológico apropiado al material',
      'Limpieza y desinfección de baños (azulejos, sanitarios, espejos, griferías)',
      'Limpieza completa de cocina (encimera, electrodomésticos exteriores, fregadero)',
      'Eliminación de polvo en muebles, estantes, rodapiés y zócalos',
      'Limpieza de cristales interiores',
      'Vaciado de papeleras y gestión básica de residuos',
      'Productos ecológicos Ecolabel incluidos',
      'Seguro de responsabilidad civil incluido',
    ],
    proceso: [
      { titulo: 'Presupuesto en 24h', desc: 'Nos dices el tamaño de la vivienda, cuántas habitaciones y baños, y si hay mascotas. En menos de 24 horas tienes precio cerrado, sin sorpresas.' },
      { titulo: 'Fijamos fecha y hora', desc: 'Elegimos juntos el día y la franja horaria que mejor te encaje. Mañana, tarde, fin de semana: nos adaptamos.' },
      { titulo: 'El equipo llega puntual', desc: 'El mismo equipo siempre. Trae todos los materiales. Tú no tienes que preparar nada.' },
      { titulo: 'Lo dejamos impecable', desc: 'Trabajamos de arriba abajo, estancia por estancia, con técnica profesional y productos ecológicos certificados.' },
    ],
    porqueNosotros: `Somos una empresa local fundada en Ferrol en 2004. No somos una franquicia ni una plataforma de intermediación: somos un equipo de personas que conocen el territorio, el tipo de vivienda gallega y sus particularidades. Llevamos más de 20 años construyendo una reputación basada en el trabajo bien hecho y la confianza de las familias que nos abren la puerta de sus hogares.`,
    articulosRelacionados: [
      { titulo: 'Cómo limpiar el piso a fondo: guía completa', href: '/blog/como-limpiar-el-piso-a-fondo/' },
      { titulo: 'Cómo mantener el piso limpio entre limpiezas profesionales', href: '/blog/como-mantener-piso-limpio-entre-limpiezas/' },
      { titulo: '¿Cuánto cuesta una limpieza del hogar en Galicia?', href: '/blog/cuanto-cuesta-limpieza-hogar/' },
    ],
  },
  'limpieza-de-oficinas': {
    intro: `La imagen de una oficina limpia y ordenada no es solo estética: afecta a la productividad del equipo, a la impresión que causa en clientes y visitas, y a la salud de las personas que trabajan allí. Polvo, bacterias en superficies de contacto frecuente y aire contaminado por productos de limpieza agresivos son problemas reales que un servicio de limpieza profesional bien ejecutado puede eliminar.`,
    parrafo2: `En Zentro Limpiezas trabajamos con empresas de todos los tamaños en Ferrol y A Coruña: desde despachos individuales y clínicas hasta oficinas de planta completa y espacios de coworking. Nos adaptamos al horario de tu empresa —antes de que llegue el equipo, durante la jornada en zonas que no interrumpan el trabajo, o al final del día— para que la limpieza no interfiera con la actividad.`,
    parrafo3: `Todos nuestros servicios de limpieza de oficinas incluyen productos ecológicos certificados, algo especialmente importante en entornos cerrados donde la ventilación es limitada. Sin olor químico agresivo, sin compuestos orgánicos volátiles que afecten al bienestar del equipo.`,
    incluye: [
      'Limpieza y desinfección de puestos de trabajo (mesas, teclados, teléfonos, sillas)',
      'Aspirado y fregado de suelos (moquetas, tarima, gres)',
      'Limpieza de zonas comunes: recepción, sala de reuniones, zonas de descanso',
      'Desinfección de baños y cocina o office',
      'Vaciado y gestión de residuos',
      'Limpieza de cristales interiores y puertas',
      'Desempolvado de equipos y mobiliario de oficina',
      'Productos ecológicos certificados incluidos',
      'Servicio adaptado al horario de la empresa',
    ],
    proceso: [
      { titulo: 'Evaluamos tus necesidades', desc: 'Tamaño del espacio, número de personas, horarios de trabajo y zonas prioritarias. Presupuesto detallado en 24h.' },
      { titulo: 'Plan personalizado', desc: 'Frecuencia, horario y scope definidos por escrito. Sin letra pequeña ni costes ocultos.' },
      { titulo: 'Mismo equipo estable', desc: 'En servicios periódicos, el mismo equipo siempre. Conocen el espacio y el protocolo de tu empresa.' },
      { titulo: 'Control de calidad', desc: 'Canal de comunicación directo con Zentro Limpiezas para cualquier incidencia o ajuste del servicio.' },
    ],
    porqueNosotros: `Trabajamos con empresas de Ferrol y A Coruña que necesitan un servicio fiable, puntual y discreto. Entendemos que en un entorno de trabajo la limpieza tiene que hacerse sin molestar, sin olor agresivo y sin sorpresas. Llevamos más de 20 años ganándose la confianza de empresas locales, y eso solo se consigue con resultados consistentes día tras día.`,
    articulosRelacionados: [
      { titulo: 'Limpieza de oficinas y empresas en Galicia', href: '/blog/limpieza-oficinas-empresas-galicia/' },
      { titulo: '¿Cuánto cuesta una limpieza profesional en Galicia?', href: '/blog/cuanto-cuesta-limpieza-hogar/' },
    ],
  },
  'limpieza-fin-de-obra': {
    intro: `La limpieza después de una obra es uno de los trabajos más exigentes y especializados que existe en el sector. El polvo de escayola y cemento se filtra por todas partes —debajo de los enchufes, en el interior de los armarios, en las ranuras del parqué—, las salpicaduras de pintura quedan en cristales y griferías, y los restos de adhesivo y silicona requieren disolventes y técnicas específicas. No es una limpieza normal: es un trabajo de especialistas.`,
    parrafo2: `En Zentro Limpiezas llevamos años realizando limpiezas de fin de obra en Ferrol, Narón, A Coruña y toda la comarca. Trabajamos tanto en obras nuevas —pisos recién construidos que necesitan una primera limpieza a fondo antes de entrar a vivir— como en reformas parciales de cocinas, baños o estancias completas. El objetivo siempre es el mismo: entregar el espacio listo para usar, sin rastro de la obra.`,
    parrafo3: `Utilizamos maquinaria profesional para la aspiración de polvo fino, productos específicos para la eliminación de restos de lechada, pintura y adhesivos, y un protocolo de trabajo que empieza siempre de arriba hacia abajo —primero techos y paredes, luego superficies y por último suelos— para no tener que repetir trabajo.`,
    incluye: [
      'Eliminación de polvo de obra en todas las superficies (techos, paredes, muebles)',
      'Limpieza de cristales con eliminación de restos de pintura y obra',
      'Limpieza de griferías, sanitarios y electrodomésticos de restos de obra',
      'Eliminación de restos de adhesivo, silicona y lechada',
      'Limpieza a fondo de suelos (incluido parqué y tarima con producto apropiado)',
      'Aspirado con filtro HEPA del polvo fino',
      'Limpieza interior de armarios y espacios de almacenamiento',
      'Gestión y retirada de residuos ligeros de limpieza',
      'Productos ecológicos incluidos',
    ],
    proceso: [
      { titulo: 'Valoramos el trabajo', desc: 'Metras, tipo de obra y materiales, estado de la suciedad. Presupuesto cerrado sin sorpresas.' },
      { titulo: 'Coordinamos con la obra', desc: 'Nos adaptamos al calendario de entrega. Podemos trabajar en fases si la reforma aún está en curso.' },
      { titulo: 'Protocolo de fin de obra', desc: 'Empezamos por arriba: techos, paredes, ventanas. Seguimos con superficies. Terminamos con suelos.' },
      { titulo: 'Entrega impecable', desc: 'El espacio queda listo para habitar o para que entren los muebles. Sin polvo, sin restos, sin obra.' },
    ],
    porqueNosotros: `La limpieza de fin de obra requiere materiales y técnicas que van más allá de la limpieza doméstica habitual. Tenemos la experiencia, el equipo y los productos específicos para este tipo de trabajo. Y lo hacemos con productos ecológicos: incluso en limpiezas de obra, evitamos disolventes agresivos cuando existen alternativas igualmente eficaces.`,
    articulosRelacionados: [
      { titulo: 'Guía de limpieza de fin de obra', href: '/blog/limpieza-fin-de-obra-guia/' },
      { titulo: 'Limpiar antes de una mudanza', href: '/blog/limpiar-antes-mudanza/' },
    ],
  },
  'limpieza-de-comunidades': {
    intro: `Las zonas comunes de un edificio son la primera impresión que reciben los vecinos y las visitas. Un portal limpio, unas escaleras sin polvo, un garaje bien mantenido: hablan del cuidado que existe en esa comunidad y contribuyen directamente al valor del inmueble. Zentro Limpiezas lleva más de 20 años gestionando contratos de limpieza de comunidades en Ferrol, Narón, A Coruña y toda la comarca.`,
    parrafo2: `Trabajamos directamente con comunidades de propietarios o a través de administradores de fincas. El contrato se adapta a las necesidades de cada edificio: la frecuencia de visitas, las zonas que cubre el servicio y el presupuesto disponible. Establecemos un calendario de trabajo claro y un contacto directo para cualquier incidencia o necesidad puntual fuera del servicio habitual.`,
    parrafo3: `A diferencia de los productos convencionales que muchas comunidades usan, nuestros productos ecológicos certificados no dejan residuos tóxicos en superficies de contacto, no generan olor agresivo en espacios cerrados como ascensores o garajes, y son más seguros para los vecinos —especialmente niños y personas mayores— que transitan por esas zonas.`,
    incluye: [
      'Limpieza de portal, escaleras y rellanos',
      'Barrido y fregado de suelos de zonas comunes',
      'Limpieza de ascensor (cabina, paredes y puerta)',
      'Limpieza de buzones, interfonos y pasamanos',
      'Limpieza de garaje y trasteros (según contrato)',
      'Gestión de residuos de zonas comunes',
      'Limpieza de cristales de portal y zonas comunes',
      'Informe y canal de comunicación con administrador o presidente',
      'Productos ecológicos certificados siempre incluidos',
    ],
    proceso: [
      { titulo: 'Reunión inicial', desc: 'Visitamos el edificio, evaluamos las zonas y elaboramos un presupuesto detallado por escrito.' },
      { titulo: 'Contrato claro', desc: 'Frecuencia, horario, zonas incluidas y precio fijo mensual. Sin sorpresas en la factura.' },
      { titulo: 'Equipo estable', desc: 'El mismo equipo siempre. Conocen el edificio y sus particularidades.' },
      { titulo: 'Comunicación directa', desc: 'Contacto directo con Zentro Limpiezas para incidencias o servicios adicionales puntuales.' },
    ],
    porqueNosotros: `Gestionamos comunidades de toda la comarca con un servicio que funciona. No tenemos turnos de empleados aleatorios: el mismo equipo, el mismo día, a la misma hora. Si hay algún problema, tienes un contacto directo, no un call center.`,
    articulosRelacionados: [
      { titulo: 'Guía de limpieza de comunidades de vecinos', href: '/blog/limpieza-comunidades-vecinos-guia/' },
      { titulo: '¿Cuánto cuesta una limpieza profesional en Galicia?', href: '/blog/cuanto-cuesta-limpieza-hogar/' },
    ],
  },
  'limpieza-a-fondo': {
    intro: `La limpieza a fondo o "gran limpieza" es el servicio que devuelve el hogar a su estado original. Va mucho más allá del mantenimiento habitual: llega a los lugares que en el día a día no se tocan —la parte trasera de los electrodomésticos, el interior de los armarios, las persianas, los zócalos, detrás y debajo de los muebles, los marcos de puertas y ventanas. Es una puesta a punto completa.`,
    parrafo2: `Se contrata habitualmente en momentos específicos: antes o después de una mudanza, al volver de vacaciones largas, en el cambio de temporada, cuando un piso ha estado mucho tiempo sin limpieza profesional o cuando simplemente el mantenimiento habitual ya no es suficiente. También es el primer servicio que hacemos cuando un cliente quiere empezar una limpieza periódica: la primera visita es siempre una limpieza a fondo para dejar la base bien establecida.`,
    parrafo3: `Una limpieza a fondo bien hecha requiere tiempo —entre 4 y 8 horas según el tamaño de la vivienda— y técnica. Trabajamos siempre de arriba hacia abajo y de dentro hacia afuera, con el orden correcto para que ninguna zona quede sucia por el trabajo en otra. Usamos productos ecológicos específicos para cada superficie y tipo de suciedad: desengrasante para la cocina, antical para baños, limpiador neutro para suelos delicados.`,
    incluye: [
      'Limpieza completa de cocina: interior de armarios, encimera, electrodomésticos (exterior e interior)',
      'Limpieza a fondo de baños: azulejos, lechadas, juntas, sanitarios, griferías',
      'Limpieza de cristales interiores y exteriores accesibles',
      'Limpieza de persianas, estores y marcos de ventanas',
      'Aspirado y fregado de todos los suelos',
      'Limpieza detrás y debajo de muebles y electrodomésticos',
      'Limpieza interior de armarios (vaciado previo por el cliente)',
      'Limpieza de rodapiés, zócalos e interruptores',
      'Desempolvado completo de techos, lámparas y esquinas',
      'Productos ecológicos certificados incluidos',
    ],
    proceso: [
      { titulo: 'Presupuesto personalizado', desc: 'Según metros cuadrados, número de habitaciones y baños, y estado general. Precio cerrado en 24h.' },
      { titulo: 'Preparación mínima', desc: 'Solo pedimos que los armarios que quieres limpiar por dentro estén vaciados antes de nuestra llegada.' },
      { titulo: 'Equipo completo', desc: 'Venimos con todo: productos, maquinaria, paños de microfibra, cepillos específicos por superficie.' },
      { titulo: 'Resultado garantizado', desc: 'Trabajamos hasta que cada zona queda como tiene que quedar. Sin prisas, con técnica.' },
    ],
    porqueNosotros: `Una limpieza a fondo hecha deprisa no es una limpieza a fondo. Nos tomamos el tiempo necesario y usamos la técnica correcta para cada superficie. Con 20 años de experiencia, sabemos dónde se acumula la suciedad que nadie ve y cómo tratarla sin dañar las superficies.`,
    articulosRelacionados: [
      { titulo: 'Cómo limpiar el piso a fondo: guía completa', href: '/blog/como-limpiar-el-piso-a-fondo/' },
      { titulo: 'Cómo limpiar la cocina a fondo', href: '/blog/limpiar-cocina-a-fondo/' },
      { titulo: 'Limpiar antes de una mudanza', href: '/blog/limpiar-antes-mudanza/' },
    ],
  },
  'limpieza-fin-de-obra': {
    intro: `La limpieza posterior a una obra o reforma es un trabajo especializado que requiere técnica, materiales adecuados y experiencia. No es una limpieza doméstica habitual. El polvo de escayola y cemento penetra en todos los huecos, las salpicaduras de pintura quedan en cristales y griferías, y los restos de adhesivos, silicona o lechada necesitan tratamiento específico.`,
    parrafo2: `En Zentro Limpiezas realizamos limpiezas de fin de obra en Ferrol, Narón, A Coruña y toda la comarca. Trabajamos en obra nueva, en reformas integrales y en reformas parciales de cocinas, baños o una sola estancia. El resultado es siempre el mismo: el espacio listo para usar, sin rastro de obra.`,
    parrafo3: `Usamos maquinaria profesional con filtros HEPA para la aspiración de polvo fino, productos específicos para cada tipo de residuo de obra y un protocolo de trabajo ordenado que garantiza que ninguna zona queda sucia por el trabajo en otra. Trabajamos de arriba hacia abajo: techos y paredes primero, luego superficies y por último suelos.`,
    incluye: [
      'Eliminación de polvo de obra en techos, paredes y superficies',
      'Limpieza de cristales con eliminación de pintura y restos de obra',
      'Limpieza de griferías y sanitarios nuevos',
      'Eliminación de restos de adhesivo, silicona y lechada en azulejos y suelos',
      'Limpieza a fondo de suelos nuevos (parqué, gres, mármol, tarima)',
      'Aspirado profesional con filtro HEPA de polvo fino',
      'Limpieza interior de armarios, cajones y espacios de almacenamiento',
      'Retirada de residuos ligeros de la limpieza',
      'Productos ecológicos incluidos',
    ],
    proceso: [
      { titulo: 'Valoramos el trabajo', desc: 'Metros cuadrados, tipo de obra, materiales y estado. Presupuesto cerrado sin sorpresas.' },
      { titulo: 'Coordinamos con la obra', desc: 'Nos adaptamos al calendario de entrega. Si la obra aún está en curso, podemos trabajar por fases.' },
      { titulo: 'Protocolo especializado', desc: 'De arriba hacia abajo. Primero polvo y restos de obra, luego limpieza de superficies y cristales, por último suelos.' },
      { titulo: 'Entrega lista para usar', desc: 'El espacio queda impecable. Sin polvo, sin restos de pintura, sin rastro de la reforma.' },
    ],
    porqueNosotros: `Hemos realizado cientos de limpiezas de fin de obra en toda la comarca. Tenemos el material, los productos específicos y la experiencia para hacerlo correctamente, respetando los materiales nuevos y dejando cada superficie en su estado óptimo.`,
    articulosRelacionados: [
      { titulo: 'Guía de limpieza de fin de obra', href: '/blog/limpieza-fin-de-obra-guia/' },
      { titulo: 'Limpiar antes de una mudanza', href: '/blog/limpiar-antes-mudanza/' },
    ],
  },
  'limpieza-de-apartamentos-turisticos': {
    intro: `Un apartamento turístico sucio o mal cuidado significa malas reseñas, cancelaciones y pérdida de ingresos. En la era en que una sola foto del cuarto de baño puede determinar la reserva, la limpieza entre huéspedes no es un gasto: es una inversión en tu valoración y en tu ocupación. En Zentro Limpiezas gestionamos la limpieza de apartamentos turísticos y alojamientos de plataformas como Airbnb en A Coruña, Ferrol y toda la costa gallega.`,
    parrafo2: `Nos adaptamos a tu calendario de check-out y check-in. Si tienes una salida a las 11:00 y una entrada a las 15:00, organizamos el servicio para que el apartamento esté listo a tiempo. El servicio incluye la limpieza completa del alojamiento, cambio de ropa de cama y toallas (si nos la facilitas o gestionamos su reposición), reposición de consumibles básicos y comprobación del estado del apartamento.`,
    parrafo3: `Usamos productos ecológicos certificados en todos nuestros servicios de apartamentos turísticos. Es importante tanto para los huéspedes —que no quieren encontrarse con olor a lejía o químico agresivo en su alojamiento— como para los anfitriones, que cada vez más reciben mejor valoración cuando mencionan que el alojamiento usa productos respetuosos con el medio ambiente.`,
    incluye: [
      'Limpieza completa de todas las estancias entre huéspedes',
      'Cambio de ropa de cama y toallas',
      'Limpieza y desinfección de baños',
      'Limpieza de cocina, electrodomésticos y utensilios',
      'Fregado y aspirado de suelos',
      'Vaciado de papeleras y gestión de residuos',
      'Reposición de consumibles (jabón, papel, etc.) si se nos facilitan',
      'Comprobación de desperfectos o necesidades del alojamiento',
      'Adaptación al calendario de check-out y check-in',
      'Productos ecológicos Ecolabel incluidos',
    ],
    proceso: [

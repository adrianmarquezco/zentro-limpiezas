---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { BUSINESS } from '@/data/config';

const canonical = `${BUSINESS.url}/legal/cookies/`;
const breadcrumbs = [
  { label: 'Política de cookies', href: '/legal/cookies/' },
];
---

<BaseLayout
  title="Política de cookies | Zentro Limpiezas"
  description="Política de cookies de Zentro Limpiezas. Qué cookies usamos y cómo desactivarlas."
  canonical={canonical}
  robots="noindex, follow"
>
  <Breadcrumbs crumbs={breadcrumbs} />
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-16 prose-zentro">
    <h1 class="font-serif text-3xl text-primary mb-8">Política de cookies</h1>

    <h2>¿Qué son las cookies?</h2>
    <p>Las cookies son pequeños archivos de texto que los sitios web almacenan en tu navegador. Sirven para recordar tus preferencias, analizar el tráfico y mejorar la experiencia de usuario.</p>

    <h2>Cookies que utilizamos</h2>
    <p>Este sitio web utiliza únicamente cookies técnicas imprescindibles para el funcionamiento básico. No utilizamos cookies de rastreo, publicidad ni analítica de terceros.</p>

    <table>
      <thead>
        <tr>
          <th>Cookie</th>
          <th>Tipo</th>
          <th>Duración</th>
          <th>Finalidad</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>No se instalan cookies de sesión ni persistentes de terceros</td>
          <td>—</td>
          <td>—</td>
          <td>—</td>
        </tr>
      </tbody>
    </table>

    <h2>Cómo gestionar las cookies</h2>
    <p>Puedes configurar tu navegador para aceptar, rechazar o eliminar cookies en cualquier momento. Ten en cuenta que deshabilitar cookies técnicas puede afectar al funcionamiento del sitio.</p>
    <ul>
      <li><a href="https://support.google.com/chrome/answer/95647" target="_blank" rel="noopener noreferrer">Chrome</a></li>
      <li><a href="https://support.mozilla.org/es/kb/habilitar-y-deshabilitar-cookies-sitios-web-rastrear-preferencias" target="_blank" rel="noopener noreferrer">Firefox</a></li>
      <li><a href="https://support.apple.com/es-es/HT201265" target="_blank" rel="noopener noreferrer">Safari</a></li>
    </ul>

    <h2>Actualizaciones de esta política</h2>
    <p>Podemos actualizar esta política para reflejar cambios en el sitio o en la normativa aplicable. Te recomendamos revisarla periódicamente.</p>

    <p class="text-mid text-sm mt-8">Última actualización: enero de 2025</p>
  </article>
</BaseLayout>

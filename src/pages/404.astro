---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { BUSINESS } from '@/data/config';

const canonical = `${BUSINESS.url}/404/`;
---

<BaseLayout
  title="Página no encontrada | Zentro Limpiezas"
  description="La página que buscas no existe. Vuelve al inicio o contáctanos."
  canonical={canonical}
  robots="noindex, nofollow"

>
  <section class="min-h-[60vh] flex items-center justify-center py-24">
    <div class="max-w-md mx-auto px-4 text-center">
      <p class="font-mono text-accent text-7xl font-bold mb-4">404</p>
      <h1 class="font-serif text-3xl text-warm mb-4">Página no encontrada</h1>
      <p class="text-mid mb-8">La dirección que buscas no existe o ha cambiado.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn btn-accent">Ir al inicio</a>
        <a href="/presupuesto/" class="btn btn-outline">Pedir presupuesto</a>
      </div>
    </div>
  </section>
</BaseLayout>

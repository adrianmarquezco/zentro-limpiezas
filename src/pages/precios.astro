---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import FAQAccordion from '@/components/ui/FAQAccordion.astro';
import SchemaFAQ from '@/components/schema/SchemaFAQ.astro';
import CTASection from '@/components/sections/CTASection.astro';
import WhatsAppFloat from '@/components/ui/WhatsAppFloat.astro';
import CTABar from '@/components/ui/CTABar.astro';
import { BUSINESS, PRICE_HINTS, buildWhatsAppUrl, WA_MESSAGES } from '@/data/config';

const canonical = `${BUSINESS.url}/precios/`;
const title = 'Precios de limpieza en Ferrol y A Coruña 2026 | Zentro Limpiezas';
const description = 'Precios orientativos de limpieza de viviendas, oficinas y locales en Ferrol, Narón y A Coruña. Desde 45€. Presupuesto gratuito en 24h. Productos ecológicos incluidos.';

const breadcrumbs = [{ label: 'Precios', href: '/precios/' }];

const waUrl = buildWhatsAppUrl(WA_MESSAGES.presupuesto);

const faqs = [
  {
    q: '¿Cuánto cuesta limpiar un piso en Ferrol o A Coruña?',
    a: 'El precio orientativo para limpiar un piso estándar de 50–70 m² en Ferrol o A Coruña empieza desde 55€ para una limpieza puntual. Un piso pequeño de hasta 50 m² desde 45€ y un piso grande de 70–100 m² desde 70€. El precio final depende del estado del inmueble, cuánto tiempo lleva sin limpieza profesional y si eliges servicio puntual o periódico.',
  },
  {
    q: '¿Los productos ecológicos tienen coste adicional?',
    a: 'No. Los productos ecológicos con certificación Ecolabel de la Unión Europea están incluidos en el precio de todos los servicios de Zentro Limpiezas. No se aplica ningún cargo adicional. Es el estándar de trabajo, no una opción premium.',
  },
  {
    q: '¿Es más barato el servicio de limpieza periódico?',
    a: 'Sí. El precio por visita en el servicio periódico (semanal, quincenal o mensual) es inferior al del servicio puntual. Además, el equipo ya conoce tu casa y cada visita es más eficiente. Para muchos clientes, el servicio quincenal resulta la opción más equilibrada entre coste y resultado.',
  },
  {
    q: '¿Cuánto cuesta una limpieza fin de obra en Ferrol?',
    a: 'El precio de la limpieza fin de obra se calcula con presupuesto personalizado porque depende de muchos factores: metros cuadrados, tipo de obra (parcial o integral), materiales (mármol, terrazo, parqué), cantidad de yeso y polvo acumulado, y si hay o no ascensores. Solicita presupuesto sin compromiso y te respondemos en menos de 24h.',
  },
  {
    q: '¿Cuánto cuesta limpiar una oficina en Ferrol o A Coruña?',
    a: 'Para despachos pequeños de hasta 40 m² el precio orientativo empieza desde 60€. Oficinas medianas de 40–80 m² desde 80€. Para open spaces o grandes oficinas el precio se calcula con presupuesto personalizado. Los productos ecológicos están incluidos y el horario se adapta al de la empresa.',
  },
  {
    q: '¿Hay algún coste si no quedo satisfecho?',
    a: 'No. Zentro Limpiezas ofrece garantía total de satisfacción: si el resultado no cumple tus expectativas, el equipo repite el servicio sin ningún coste adicional. En más de 20 años de actividad nunca ha sido necesario, pero la garantía existe y está por escrito.',
  },
  {
    q: '¿Cómo se obtiene un presupuesto personalizado?',
    a: 'Puedes solicitar presupuesto gratuito y sin compromiso por WhatsApp al 616 054 001, llamando al mismo número, o mediante el formulario en zentrolimpiezas.es. Te respondemos con un precio cerrado en menos de 24 horas. No hace falta visita previa en la mayoría de casos.',
  },
];
---

<BaseLayout {title} {description} {canonical} lang="es" hreflangEs={canonical}>
  <SchemaFAQ faqs={faqs} />
  <Breadcrumbs crumbs={breadcrumbs} dark={true} />

  <!-- Hero -->
  <section class="hero-section bg-primary py-16 lg:py-20 relative noise-overlay overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-2xl">
        <span class="hero-eyebrow inline-block bg-accent/10 text-accent border border-accent/30 rounded-full px-4 py-1 text-sm font-medium mb-5">
          Precios actualizados 2026 · Ferrol y A Coruña
        </span>
        <h1 class="font-display text-4xl sm:text-5xl text-white leading-tight mb-4">
          Precios de limpieza profesional<br>
          <span class="text-accent">en Ferrol y A Coruña</span>
        </h1>
        <p class="text-white/75 text-lg leading-relaxed speakable-intro">
          Precios orientativos para limpieza de viviendas, oficinas y locales en 2026. Productos ecológicos Ecolabel incluidos en todos los servicios. Presupuesto personalizado y cerrado en menos de 24h, sin compromiso.
        </p>
      </div>
    </div>
  </section>

  <!-- Tablas de precios -->
  <section class="py-16 lg:py-24 bg-warm">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-14">

      <!-- Viviendas -->
      <div data-reveal>
        <h2 class="font-display text-2xl lg:text-3xl text-primary mb-2">¿Cuánto cuesta limpiar una vivienda en Ferrol y A Coruña?</h2>
        <p class="text-charcoal text-base leading-relaxed mb-6 speakable-intro">
          El precio de limpieza de vivienda en Ferrol y A Coruña empieza desde 45€ para pisos pequeños de hasta 50 m². Para pisos estándar de 50–70 m² el precio habitual es desde 55€. El precio final depende del estado del inmueble, la frecuencia y si hay mascotas o requisitos especiales.
        </p>
        <div class="bg-white rounded-2xl border border-line overflow-hidden">
          <div class="bg-primary px-5 py-3 flex items-center justify-between">
            <span class="font-semibold text-white text-sm">Limpieza de vivienda — Precios orientativos 2026</span>
            <span class="text-accent text-xs font-semibold">Eco incluido</span>
          </div>
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-warm">
                <th class="text-left px-5 py-2.5 font-semibold text-primary text-xs uppercase tracking-wide">Tipo de inmueble</th>
                <th class="text-left px-5 py-2.5 font-semibold text-primary text-xs uppercase tracking-wide">Tamaño</th>
                <th class="text-left px-5 py-2.5 font-semibold text-primary text-xs uppercase tracking-wide">Precio orientativo</th>
              </tr>
            </thead>
            <tbody>
              {PRICE_HINTS.vivienda.map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-warm/40'}>
                  <td class="px-5 py-3 text-charcoal font-medium">{row.tipo}</td>
                  <td class="px-5 py-3 text-mid">{row.tamano}</td>
                  <td class="px-5 py-3 font-bold text-primary">{row.precio}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="px-5 py-3 text-xs text-mid bg-warm/30 border-t border-line">{PRICE_HINTS.disclaimer}</p>
        </div>
      </div>

      <!-- Oficinas -->
      <div data-reveal>
        <h2 class="font-display text-2xl lg:text-3xl text-primary mb-2">¿Cuánto cuesta limpiar una oficina en Ferrol y A Coruña?</h2>
        <p class="text-charcoal text-base leading-relaxed mb-6">
          El precio de limpieza de oficina en Ferrol y A Coruña empieza desde 60€ para despachos pequeños de hasta 40 m². Para oficinas medianas de 40–80 m² el precio habitual es desde 80€. El horario se adapta al de la empresa: antes de abrir, después de cerrar o fines de semana.
        </p>
        <div class="bg-white rounded-2xl border border-line overflow-hidden">
          <div class="bg-primary px-5 py-3 flex items-center justify-between">
            <span class="font-semibold text-white text-sm">Limpieza de oficina — Precios orientativos 2026</span>
            <span class="text-accent text-xs font-semibold">Eco incluido</span>
          </div>
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-warm">
                <th class="text-left px-5 py-2.5 font-semibold text-primary text-xs uppercase tracking-wide">Tipo</th>
                <th class="text-left px-5 py-2.5 font-semibold text-primary text-xs uppercase tracking-wide">Tamaño</th>
                <th class="text-left px-5 py-2.5 font-semibold text-primary text-xs uppercase tracking-wide">Precio orientativo</th>
              </tr>
            </thead>
            <tbody>
              {PRICE_HINTS.oficina.map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-warm/40'}>
                  <td class="px-5 py-3 text-charcoal font-medium">{row.tipo}</td>
                  <td class="px-5 py-3 text-mid">{row.tamano}</td>
                  <td class="px-5 py-3 font-bold text-primary">{row.precio}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="px-5 py-3 text-xs text-mid bg-warm/30 border-t border-line">{PRICE_HINTS.disclaimer}</p>
        </div>
      </div>

      <!-- Locales -->
      <div data-reveal>
        <h2 class="font-display text-2xl lg:text-3xl text-primary mb-2">¿Cuánto cuesta limpiar un local comercial en Ferrol y A Coruña?</h2>
        <p class="text-charcoal text-base leading-relaxed mb-6">
          El precio de limpieza de local comercial empieza desde 70€ para locales pequeños de hasta 50 m². Para bares, restaurantes o comercios con mayor exigencia, el precio se calcula con presupuesto personalizado según las necesidades específicas.
        </p>
        <div class="bg-white rounded-2xl border border-line overflow-hidden">
          <div class="bg-primary px-5 py-3 flex items-center justify-between">
            <span class="font-semibold text-white text-sm">Limpieza de local — Precios orientativos 2026</span>
            <span class="text-accent text-xs font-semibold">Eco incluido</span>
          </div>
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-warm">
                <th class="text-left px-5 py-2.5 font-semibold text-primary text-xs uppercase tracking-wide">Tipo</th>
                <th class="text-left px-5 py-2.5 font-semibold text-primary text-xs uppercase tracking-wide">Tamaño</th>
                <th class="text-left px-5 py-2.5 font-semibold text-primary text-xs uppercase tracking-wide">Precio orientativo</th>
              </tr>
            </thead>
            <tbody>
              {PRICE_HINTS.local.map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-warm/40'}>
                  <td class="px-5 py-3 text-charcoal font-medium">{row.tipo}</td>
                  <td class="px-5 py-3 text-mid">{row.tamano}</td>
                  <td class="px-5 py-3 font-bold text-primary">{row.precio}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="px-5 py-3 text-xs text-mid bg-warm/30 border-t border-line">{PRICE_HINTS.disclaimer}</p>
        </div>
      </div>

      <!-- ¿Qué incluye el precio? -->
      <div class="bg-primary noise-overlay rounded-2xl p-8 lg:p-10 relative overflow-hidden" data-reveal>
        <h2 class="font-display text-2xl lg:text-3xl text-white mb-6">¿Qué incluye siempre el precio de Zentro Limpiezas?</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            { title: 'Productos ecológicos Ecolabel', desc: 'Certificados por la Unión Europea. Sin coste adicional.' },
            { title: 'Mismo equipo de profesionales', desc: 'En servicios periódicos, siempre las mismas personas.' },
            { title: 'Desplazamiento incluido', desc: 'Sin recargo por distancia dentro de nuestra zona de cobertura.' },
            { title: 'Garantía de satisfacción', desc: 'Si el resultado no te convence, repetimos sin coste.' },
            { title: 'Presupuesto cerrado', desc: 'El precio acordado es el precio final. Sin sorpresas.' },
            { title: 'Seguro de responsabilidad civil', desc: 'Cubiertos ante cualquier incidencia durante el trabajo.' },
          ].map(item => (
            <div class="flex gap-3">
              <svg class="text-accent mt-0.5 shrink-0 w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <p class="text-white text-sm font-semibold">{item.title}</p>
                <p class="text-white/60 text-xs mt-0.5">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA Presupuesto -->
      <div class="text-center py-4" data-reveal>
        <h2 class="font-display text-2xl lg:text-3xl text-primary mb-3">Pide tu presupuesto personalizado</h2>
        <p class="text-mid text-lg mb-6 max-w-xl mx-auto">Sin compromiso. Precio cerrado en menos de 24 horas. Sin visita previa necesaria en la mayoría de casos.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/presupuesto/" class="btn-primary px-8 py-4 text-base">→ Formulario de presupuesto</a>
          <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp px-8 py-4 text-base">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            WhatsApp · {BUSINESS.phoneDisplay}
          </a>
        </div>
        <p class="text-mid text-sm mt-3">Sin compromiso · Respuesta garantizada en menos de 24h</p>
      </div>

    </div>
  </section>

  <!-- FAQ precios -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10" data-reveal>
        <h2 class="font-display text-2xl lg:text-3xl text-primary mb-3">Preguntas frecuentes sobre precios de limpieza en Ferrol y A Coruña</h2>
      </div>
      <div data-reveal>
        <FAQAccordion faqs={faqs} />
      </div>
    </div>
  </section>

  <CTASection />
  <WhatsAppFloat />
  <CTABar />
</BaseLayout>

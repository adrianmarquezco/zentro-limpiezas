---
import BlogLayout from '@/layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import { BUSINESS } from '@/data/config';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const postsGL = await getCollection('blog-gl', ({ data }) => !data.draft);
  return posts.map((post) => {
    const glMatch = postsGL.find(p => p.data.slugEs === post.slug);
    return {
      params: { slug: post.slug },
      props: { post, glSlug: glMatch?.slug ?? null },
    };
  });
}

const { post, glSlug } = Astro.props;
const { Content } = await post.render();
const canonical = `${BUSINESS.url}/blog/${post.slug}/`;
const hreflangGl = glSlug ? `${BUSINESS.url}/gl/blog/${glSlug}/` : undefined;

const breadcrumbs = [
  { label: 'Blog', href: '/blog/' },
  { label: post.data.title, href: canonical },
];
---

<BlogLayout
  title={`${post.data.title} | Zentro Limpiezas`}
  description={post.data.description}
  {canonical}
  lang="es"
  datePublished={post.data.datePublished}
  dateModified={post.data.dateModified}
  image={post.data.image}
  readingTime={post.data.readingTime}
  category={post.data.category}
  {breadcrumbs}
  hreflangEs={canonical}
  {hreflangGl}
  faqs={post.data.faqs}
>
  <Content />
</BlogLayout>

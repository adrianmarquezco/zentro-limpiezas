---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import CTASection from '@/components/sections/CTASection.astro';
import WhatsAppFloat from '@/components/ui/WhatsAppFloat.astro';
import CTABar from '@/components/ui/CTABar.astro';
import { getCollection } from 'astro:content';
import { BUSINESS } from '@/data/config';

const canonical = `${BUSINESS.url}/blog/`;
const title = 'Blog de limpieza y hogar | Zentro Limpiezas';
const description = 'Consejos de limpieza profesional, trucos para el hogar, guías ecológicas y novedades del sector. Blog de Zentro Limpiezas en Ferrol y A Coruña.';

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Blog', href: '/blog/' },
];

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime());
---

<BaseLayout {title} {description} {canonical} lang="es" hreflangEs={canonical} hreflangGl={`${BUSINESS.url}/gl/blog/`}>
  <Breadcrumbs crumbs={breadcrumbs} />

  <section class="bg-primary py-16 relative">
    <div class="noise-overlay" />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-serif text-4xl lg:text-5xl text-warm mb-4" data-reveal>Blog</h1>
      <p class="text-mid text-lg max-w-xl" data-reveal>
        Consejos de limpieza, guías ecológicas y todo lo que necesitas saber para mantener tu hogar en perfecto estado.
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article class="card flex flex-col" data-reveal>
            <div class="p-6 flex flex-col gap-3 flex-1">
              <time class="text-mid text-xs font-mono" datetime={post.data.datePublished}>
                {new Date(post.data.datePublished).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="font-serif text-xl text-warm leading-snug">
                <a href={`/blog/${post.slug}/`} class="hover:text-accent transition-colors">
                  {post.data.title}
                </a>
              </h2>
              <p class="text-mid text-sm leading-relaxed flex-1">{post.data.description}</p>
              <a href={`/blog/${post.slug}/`} class="text-accent text-sm hover:underline mt-auto pt-4 border-t border-line block">
                Leer artículo →
              </a>
            </div>
          </article>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="text-center py-16 text-mid">
          <p>Próximamente — artículos sobre limpieza y hogar.</p>
        </div>
      )}
    </div>
  </section>

  <CTASection />
  <WhatsAppFloat />
  <CTABar />
</BaseLayout>

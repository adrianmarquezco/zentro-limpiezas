---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import CTASection from '@/components/sections/CTASection.astro';
import WhatsAppFloat from '@/components/ui/WhatsAppFloat.astro';
import CTABar from '@/components/ui/CTABar.astro';
import TrustBar from '@/components/ui/TrustBar.astro';
import EcoBadge from '@/components/ui/EcoBadge.astro';
import { BUSINESS } from '@/data/config';

const canonical = `${BUSINESS.url}/gl/sobre-nos/`;
const hreflangEs = `${BUSINESS.url}/sobre-nosotros/`;
const title = 'Sobre Zentro Limpiezas | Empresa de limpeza en Ferrol | +20 anos de experiencia';
const description = 'Zentro Limpiezas, fundada en 2026 por profesionais con máis de 20 anos no sector da limpeza en Galicia. Produtos ecolóxicos incluídos. 29+ concellos. Orzamento en 24h.';

const breadcrumbs = [
  { label: 'Sobre nós', href: '/gl/sobre-nos/' },
];

const valores = [
  {
    title: 'Profesionalidade',
    desc: 'Cada traballo faise co mesmo nivel de esixencia, tanto se é un piso pequeno como unha gran empresa.',
  },
  {
    title: 'Confianza',
    desc: 'Entramos no teu fogar ou na túa empresa. Iso implica unha responsabilidade que tomamos moi en serio.',
  },
  {
    title: 'Respecto ao medio ambiente',
    desc: 'Produtos ecolóxicos certificados en cada servizo. Sen escusas, sen custos extra.',
  },
  {
    title: 'Proximidade',
    desc: 'Somos unha empresa local. Coñecemos a comarca e o carácter da xente que vive aquí.',
  },
];

const stats = [
  { num: '+20', label: 'anos de experiencia' },
  { num: '29', label: 'concellos cubertos' },
  { num: '100%', label: 'ecolóxico sempre' },
  { num: '2026', label: 'ano de fundación' },
];

const porque = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
    title: 'Empresa local',
    desc: 'Nados e criados en Ferrol. Coñecemos o territorio e a xente.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>',
    title: 'Ecolóxico incluído',
    desc: 'Sen recargos por usar produtos responsables. É o noso estándar.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>',
    title: 'Horario flexible',
    desc: 'Tardes, fins de semana, festivos. Adaptámonos a ti.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
    title: 'Mesmo equipo',
    desc: 'Nos servizos periódicos, sempre os mesmos profesionais.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
    title: 'Orzamento en 24h',
    desc: 'Sen visita obrigatoria. Por teléfono, WhatsApp ou formulario.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    title: 'Seguro de RC',
    desc: 'Cubertos fronte a calquera incidencia durante o traballo.',
  },
];
---

<BaseLayout {title} {description} {canonical} lang="gl" hreflangGl={canonical} hreflangEs={hreflangEs}>
  <Breadcrumbs crumbs={breadcrumbs} dark={true} />

  <!-- Hero -->
  <section class="hero-section bg-primary py-20 lg:py-28 relative">
    <div class="noise-overlay" />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <span class="hero-eyebrow inline-block bg-accent/10 text-accent border border-accent/30 rounded-full px-4 py-1 text-sm font-medium mb-6">
          Ferrol, Galicia · Fundada en 2026 · +20 anos no sector
        </span>
        <h1 class="font-serif text-4xl lg:text-5xl text-warm leading-tight mb-4">
          Zentro Limpiezas:<br>
          <span class="text-accent">limpeza profesional</span><br>
          en Ferrol e A Coruña
        </h1>
        <p class="text-white/70 text-lg leading-relaxed speakable-intro">
          Zentro naceu en 2026, pero a experiencia de quen a creou non é nova. Levamos máis de 20 anos dentro do sector: traballando en empresas de limpeza, aprendendo os procesos, coñecendo o que falla e o que os clientes necesitan de verdade. Iso é o que hai detrás de cada servizo.
        </p>
      </div>
    </div>
  </section>

  <!-- Historia -->
  <section class="py-16 lg:py-24 bg-warm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div class="space-y-6">
          <div data-reveal>
            <div class="flex items-center gap-3 mb-4">
              <span class="section-number">01</span>
              <h2 class="font-serif text-2xl lg:text-3xl text-primary">A nosa historia</h2>
            </div>
            <div class="space-y-4 text-charcoal leading-relaxed">
              <p>Zentro Limpiezas naceu en 2026, pero quen a fundou leva máis de 20 anos traballando no sector da limpeza profesional en Galicia: primeiro como parte de equipos en empresas de limpeza da comarca, despois tamén pola súa conta. Esa traxectoria deu algo que non se improvisa: saber exactamente que falla habitualmente e como evitalo.</p>
              <p>Zentro naceu para facer as cousas ben desde o primeiro día: equipo propio e fixo, produtos ecolóxicos certificados incluídos en todos os servizos, prezos transparentes e garantía de satisfacción real. Non como promesas, senón como resultado de anos vendo o que os clientes necesitan e o que as empresas do sector non lles dan.</p>
              <p>Hoxe traballamos en máis de 29 concellos de Ferrolterra e a área metropolitana de A Coruña, cun equipo estable que coñece perfectamente cada zona e as súas particularidades.</p>
            </div>
          </div>

          <div data-reveal>
            <div class="flex items-center gap-3 mb-4">
              <span class="section-number">02</span>
              <h2 class="font-serif text-2xl text-primary">Os nosos valores</h2>
            </div>
            <ul class="space-y-4">
              {valores.map(v => (
                <li class="flex items-start gap-3">
                  <svg class="text-accent mt-1 shrink-0 w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <div>
                    <p class="text-primary font-medium text-sm">{v.title}</p>
                    <p class="text-mid text-sm mt-1">{v.desc}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="space-y-6">
          <div class="grid grid-cols-2 gap-4" data-reveal>
            {stats.map(item => (
              <div class="card p-6 text-center">
                <p class="font-mono text-accent text-3xl font-bold">{item.num}</p>
                <p class="text-mid text-sm mt-2">{item.label}</p>
              </div>
            ))}
          </div>

          <div class="card p-6 border-accent/30" data-reveal>
            <div class="flex items-center gap-3 mb-4">
              <EcoBadge size="md" />
            </div>
            <h3 class="font-serif text-lg text-primary mb-3">Compromiso ecolóxico</h3>
            <p class="text-mid text-sm leading-relaxed">
              Usamos exclusivamente produtos de limpeza con certificación ecolóxica Ecolabel. Son igual de eficaces que os convencionais, pero sen produtos químicos agresivos para a túa familia nin para o entorno natural de Galicia.
            </p>
            <p class="text-mid text-sm mt-3 font-medium text-accent">
              Incluído no prezo. Sen recargas. Sempre.
            </p>
          </div>

          <div class="card p-6" data-reveal>
            <h3 class="font-serif text-lg text-primary mb-3">Onde traballamos</h3>
            <p class="text-mid text-sm leading-relaxed mb-3">
              A nosa sede está en Ferrol, pero operamos en toda Ferrolterra e a área metropolitana de A Coruña: máis de 29 concellos cubertos.
            </p>
            <a href="/gl/zonas/" class="text-accent text-sm hover:underline">Ver todas as zonas →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Por que nós -->
  <section class="py-16 bg-charcoal overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-display text-2xl lg:text-3xl text-warm mb-6" data-reveal>Por que elixir Zentro Limpiezas?</h2>
        <div class="grid sm:grid-cols-2 gap-4 mt-8" data-reveal-stagger>
          {porque.map(item => (
            <div class="card p-5 flex items-start gap-3 text-left">
              <span class="text-accent shrink-0 mt-0.5 [&>svg]:w-5 [&>svg]:h-5" set:html={item.icon}></span>
              <div>
                <p class="text-primary font-medium text-sm">{item.title}</p>
                <p class="text-mid text-xs mt-1">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="bg-primary py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <TrustBar variant="dark" lang="gl" />
    </div>
  </div>
  <CTASection lang="gl" />
  <WhatsAppFloat lang="gl" />
  <CTABar lang="gl" />
</BaseLayout>

---
import ServiceLayout from '@/layouts/ServiceLayout.astro';
import HeroService from '@/components/sections/HeroService.astro';
import FAQAccordion from '@/components/ui/FAQAccordion.astro';
import EcoBadge from '@/components/ui/EcoBadge.astro';
import ContactStrip from '@/components/sections/ContactStrip.astro';
import { SERVICIOS } from '@/data/servicios';
import { BUSINESS } from '@/data/config';

export function getStaticPaths() {
  return SERVICIOS.map((s) => ({
    params: { servizo: s.slugGL },
    props: { servicio: s },
  }));
}

const { servicio } = Astro.props;
const canonical = `${BUSINESS.url}/gl/servizos/${servicio.slugGL}/`;
const hreflangEs = `${BUSINESS.url}/servicios/${servicio.slug}/`;

const title = `${servicio.nombreGL} en Galicia | Zentro Limpiezas`;
const description = `${servicio.descripcionCorta} Produtos ecolóxicos incluídos. Máis de 20 anos de experiencia en Ferrol e A Coruña.`;

const breadcrumbs = [
  { label: 'Inicio', href: '/gl/' },
  { label: 'Servizos', href: '/gl/servizos/' },
  { label: servicio.nombreGL, href: canonical },
];

const faqs = [
  { q: `¿Canto custa o servizo de ${servicio.nombreGL.toLowerCase()}?`, a: servicio.precioDesde ? `O prezo comeza desde ${servicio.precioDesde}. O orzamento final depende do tamaño e estado. Dámocho gratis e sen compromiso.` : `O prezo depende do tamaño e estado. Facémoslle un orzamento personalizado e gratuíto sen compromiso.` },
  { q: 'Os produtos ecolóxicos teñen custo adicional?', a: 'Non. Todos os nosos servizos inclúen produtos de limpeza con certificación ecolóxica sen custo extra.' },
  { q: 'Traballades fins de semana?', a: 'Si. O noso horario de atención é de luns a venres de 8:00 a 14:00 e sábados de 9:00 a 14:00, pero realizamos servizos tamén tardes e fins de semana.' },
];
---

<ServiceLayout
  {title}
  {description}
  {canonical}
  lang="gl"
  serviceName={servicio.nombreGL}
  serviceDesc={servicio.descripcionCorta}
  price={servicio.precioDesde ?? undefined}
  {faqs}
  {breadcrumbs}
  {hreflangEs}
  hreflangGl={canonical}
>
  <HeroService
    servicio={servicio.nombreGL}
    eyebrow="Limpeza profesional · Produtos ecolóxicos"
    h1={`${servicio.nombreGL}<br><span class="text-accent">en Galicia</span>`}
    subtitle={servicio.descripcionCorta}
    precioDesde={servicio.precioDesde}
    lang="gl"
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h2 class="font-serif text-2xl lg:text-3xl text-warm mb-4" data-reveal>{servicio.nombreGL} profesional</h2>
            <p class="text-mid leading-relaxed speakable-intro" data-reveal>{servicio.descripcionCorta}</p>
          </div>
          <div data-reveal>
            <h3 class="font-serif text-xl text-warm mb-4">Que inclúe?</h3>
            <ul class="space-y-2">
              {['Man de obra especializada', 'Produtos de limpeza ecolóxicos certificados', 'Material e maquinaria profesional', 'Seguro de responsabilidade civil', 'Orzamento personalizado sen compromiso'].map(item => (
                <li class="flex items-start gap-2 text-mid text-sm">
                  <span class="text-accent mt-0.5 shrink-0">✓</span>{item}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <aside class="space-y-6">
          <div class="card p-6" data-reveal>
            <h3 class="font-serif text-lg text-warm mb-4">Solicitar orzamento</h3>
            {servicio.precioDesde && <p class="font-mono text-accent text-2xl mb-4">desde {servicio.precioDesde}</p>}
            <div class="flex flex-col gap-2">
              <a href="/gl/orzamento/" class="btn btn-accent w-full text-center">Pedir orzamento</a>
              <a href={BUSINESS.phoneHref} class="btn btn-outline w-full text-center">{BUSINESS.phoneDisplay}</a>
            </div>
            <div class="mt-4 pt-4 border-t border-line"><EcoBadge size="sm" /></div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="py-16 bg-charcoal">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-2xl text-warm mb-8 text-center" data-reveal>Preguntas frecuentes</h2>
      <FAQAccordion {faqs} />
    </div>
  </section>

  <ContactStrip lang="gl" />
</ServiceLayout>

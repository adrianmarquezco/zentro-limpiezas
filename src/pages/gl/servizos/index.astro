---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import ServiceGrid from '@/components/sections/ServiceGrid.astro';
import CTASection from '@/components/sections/CTASection.astro';
import WhatsAppFloat from '@/components/ui/WhatsAppFloat.astro';
import CTABar from '@/components/ui/CTABar.astro';
import { BUSINESS } from '@/data/config';

const canonical = `${BUSINESS.url}/gl/servizos/`;
const breadcrumbs = [
  { label: 'Inicio', href: '/gl/' },
  { label: 'Servizos', href: '/gl/servizos/' },
];
---

<BaseLayout
  title="Servizos de limpeza profesional en Galicia | Zentro Limpiezas"
  description="Limpeza de vivendas, oficinas, locais, comunidades, fin de obra e máis. Produtos ecolóxicos incluídos. Máis de 20 anos en Ferrol e A Coruña."
  canonical={canonical}
  lang="gl"
  hreflangEs={`${BUSINESS.url}/servicios/`}
  hreflangGl={canonical}
>
  <Breadcrumbs crumbs={breadcrumbs} />
  <section class="hero-section bg-primary py-20 relative">
    <div class="noise-overlay" />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-serif text-4xl lg:text-5xl text-warm mb-4" data-reveal>Os nosos servizos de limpeza</h1>
      <p class="text-mid text-lg max-w-xl" data-reveal>Desde a limpeza puntual do teu piso ata contratos periódicos para empresas. Sempre con produtos ecolóxicos incluídos.</p>
    </div>
  </section>
  <ServiceGrid lang="gl" />
  <CTASection lang="gl" />
  <WhatsAppFloat lang="gl" />
  <CTABar lang="gl" />
</BaseLayout>

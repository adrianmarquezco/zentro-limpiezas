---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import SchemaArticle from '@/components/schema/SchemaArticle.astro';
import CTASection from '@/components/sections/CTASection.astro';
import WhatsAppFloat from '@/components/ui/WhatsAppFloat.astro';
import CTABar from '@/components/ui/CTABar.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  lang?: 'es' | 'gl';
  datePublished: string;
  dateModified?: string;
  image?: string;
  readingTime?: number;
  breadcrumbs: { label: string; href: string }[];
  hreflangEs?: string;
  hreflangGl?: string;
}

const {
  title, description, canonical, lang = 'es',
  datePublished, dateModified, image, readingTime,
  breadcrumbs, hreflangEs, hreflangGl,
} = Astro.props;

const locale = lang === 'gl' ? 'gl-ES' : 'es-ES';
const pubDate = new Date(datePublished).toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' });
const modDate = dateModified ? new Date(dateModified).toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' }) : null;
---

<BaseLayout {title} {description} {canonical} {lang} {hreflangEs} {hreflangGl} ogType="article">
  <SchemaArticle {title} {description} {datePublished} {dateModified} url={canonical} {image} />
  <Breadcrumbs crumbs={breadcrumbs} />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-3 text-xs text-mid font-mono mb-4">
        <time datetime={datePublished}>{pubDate}</time>
        {readingTime && <span>· {readingTime} min de lectura</span>}
        {modDate && dateModified !== datePublished && (
          <span class="text-accent">· Actualizado: {modDate}</span>
        )}
      </div>
      <h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl text-primary leading-tight">{title}</h1>
      <p class="text-mid text-lg mt-4 leading-relaxed speakable-intro">{description}</p>
    </header>
    <div class="prose-zentro">
      <slot />
    </div>
  </article>

  <CTASection {lang} />
  <WhatsAppFloat {lang} />
  <CTABar {lang} />
</BaseLayout>

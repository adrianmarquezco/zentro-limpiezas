---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import SchemaArticle from '@/components/schema/SchemaArticle.astro';
import CTASection from '@/components/sections/CTASection.astro';
import WhatsAppFloat from '@/components/ui/WhatsAppFloat.astro';
import CTABar from '@/components/ui/CTABar.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  lang?: 'es' | 'gl';
  datePublished: string;
  dateModified?: string;
  image?: string;
  breadcrumbs: { label: string; href: string }[];
  hreflangEs?: string;
  hreflangGl?: string;
}

const {
  title, description, canonical, lang = 'es',
  datePublished, dateModified, image,
  breadcrumbs, hreflangEs, hreflangGl,
} = Astro.props;
---

<BaseLayout {title} {description} {canonical} {lang} {hreflangEs} {hreflangGl} ogType="article">
  <SchemaArticle {title} {description} {datePublished} {dateModified} url={canonical} {image} />
  <Breadcrumbs crumbs={breadcrumbs} />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-16 prose-zentro">
    <header class="mb-10">
      <time class="text-mid text-sm font-mono" datetime={datePublished}>
        {new Date(datePublished).toLocaleDateString(lang === 'gl' ? 'gl-ES' : 'es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl text-warm mt-3 leading-tight">{title}</h1>
      <p class="text-mid text-lg mt-4 leading-relaxed">{description}</p>
    </header>
    <div class="prose-content">
      <slot />
    </div>
  </article>

  <CTASection {lang} />
  <WhatsAppFloat {lang} />
  <CTABar {lang} />
</BaseLayout>

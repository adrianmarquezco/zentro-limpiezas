---
import { BUSINESS } from '@/data/config';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import SchemaLocalBusiness from '@/components/schema/SchemaLocalBusiness.astro';
import CookieBanner from '@/components/ui/CookieBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  lang?: 'es' | 'gl';
  hreflangEs?: string;
  hreflangGl?: string;
  robots?: string;
  schema?: object;
}

const {
  title,
  description,
  canonical,
  ogImage = `${BUSINESS.url}/images/hero-equipo.webp`,
  ogType = 'website',
  lang = 'es',
  hreflangEs,
  hreflangGl,
  robots,
  schema,
} = Astro.props;

const canonicalUrl = canonical ?? `${BUSINESS.url}${Astro.url.pathname}`;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0A2540" />

  <!-- SEO básico -->
  <title>{title}</title>
  <meta name="description" content={description} />
  {(robots || import.meta.env.PUBLIC_NOINDEX === 'true') && (
    <meta name="robots" content={import.meta.env.PUBLIC_NOINDEX === 'true' ? 'noindex, nofollow' : robots} />
  )}
  <link rel="canonical" href={canonicalUrl} />

  <!-- hreflang -->
  {hreflangEs && <link rel="alternate" hreflang="es" href={hreflangEs} />}
  {hreflangGl && <link rel="alternate" hreflang="gl" href={hreflangGl} />}
  {hreflangEs && <link rel="alternate" hreflang="x-default" href={hreflangEs} />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Zentro Limpiezas" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content={lang === 'gl' ? 'gl_ES' : 'es_ES'} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Tipografías — carga asíncrona para no bloquear render (FOUT controlado con font-display:swap) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    onload="this.onload=null;this.rel='stylesheet'"
    href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
  />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" />
  </noscript>

  <!-- Favicon + PWA -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="apple-touch-icon" href="/images/logo.png" />
  <link rel="manifest" href="/manifest.json" />

  <!-- Preload LCP image (hero) -->
  <link rel="preload" as="image" href="/images/hero-equipo.webp" fetchpriority="high" />

  <!-- Speakable schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    url: canonicalUrl,
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.speakable-intro', 'h1'],
    },
  })} />

  <!-- Schema global -->
  <SchemaLocalBusiness />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
</head>

<body class="bg-warm font-sans antialiased">
  <Header lang={lang} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} />
  <CookieBanner lang={lang} />

  <!-- Scripts -->
  <script src="/scripts/scroll-reveal.js" defer></script>
  <script src="/scripts/header-scroll.js" defer></script>
  <script src="/scripts/faq-accordion.js" defer></script>
  <script src="/scripts/external-links.js" defer></script>

  <!-- Exit intent — solo desktop, solo 1 vez por sesión -->
  <script is:inline>
  (function() {
    if (window.innerWidth < 768 || sessionStorage.getItem('ei')) return;
    document.addEventListener('mouseleave', function handler(e) {
      if (e.clientY > 0) return;
      sessionStorage.setItem('ei', '1');
      document.removeEventListener('mouseleave', handler);
      var d = document.createElement('div');
      d.id = 'ei-overlay';
      d.style.cssText = 'position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:rgba(10,37,64,0.82);backdrop-filter:blur(8px);opacity:0;transition:opacity .25s';
      d.innerHTML = '<div style="background:#fff;border-radius:20px;padding:36px 32px;max-width:400px;width:90%;text-align:center;position:relative;box-shadow:0 30px 80px rgba(10,37,64,.35)">'
        + '<button onclick="document.getElementById(\'ei-overlay\').remove()" style="position:absolute;top:14px;right:16px;background:none;border:none;font-size:18px;color:#9CA3AF;cursor:pointer;line-height:1">✕</button>'
        + '<p style="font-size:36px;margin-bottom:12px">🧹</p>'
        + '<h3 style="font-family:Georgia,serif;font-size:21px;color:#0A2540;margin:0 0 8px">¿Te vas sin pedir presupuesto?</h3>'
        + '<p style="color:#6B7280;font-size:13px;line-height:1.6;margin:0 0 24px">Es gratis, sin compromiso y respondemos en menos de 24h. Llevamos 20 años limpiando en Ferrol y A Coruña.</p>'
        + '<div style="display:flex;flex-direction:column;gap:10px">'
        + '<a href="/presupuesto/" style="display:block;background:#0A2540;color:#fff;padding:13px 24px;border-radius:50px;font-weight:600;font-size:14px;text-decoration:none">→ Pedir presupuesto gratis</a>'
        + '<a href="https://wa.me/34616054001?text=Hola%2C+me+gustar%C3%ADa+pedir+presupuesto" target="_blank" style="display:block;background:#25D366;color:#fff;padding:13px 24px;border-radius:50px;font-weight:600;font-size:14px;text-decoration:none">WhatsApp · 616 054 001</a>'
        + '</div>'
        + '<p style="color:#D1D5DB;font-size:11px;margin-top:16px;margin-bottom:0">Sin compromisos · Cerramos cuando quieras</p>'
        + '</div>';
      d.addEventListener('click', function(e){ if(e.target===d) d.remove(); });
      document.body.appendChild(d);
      requestAnimationFrame(function(){ d.style.opacity='1'; });
    });
  })();
  </script>
</body>
</html>

---
import type { Servicio } from '@/data/servicios';

interface Props {
  servicio: Servicio;
  lang?: 'es' | 'gl';
}
const { servicio, lang = 'es' } = Astro.props;
const nombre = lang === 'gl' ? servicio.nombreGL : servicio.nombre;
const prefix = lang === 'gl' ? '/gl/servizos/' : '/servicios/';
const slugRoute = lang === 'gl' ? servicio.slugGL : servicio.slug;
const href = `${prefix}${slugRoute}/`;

const icons: Record<string, string> = {
  house: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 256 256"><path d="M240,212H224V136l8.28-8.28a8,8,0,0,0-11.32-11.32l-2.95,2.95L128,29.37,37,119.34l-2.95-2.95a8,8,0,0,0-11.32,11.32L32,136v76H16a8,8,0,0,0,0,16H240a8,8,0,0,0,0-16ZM208,212H168V160a8,8,0,0,0-8-8H96a8,8,0,0,0-8,8v52H48V124.69l80-80,80,80ZM104,212V168h48v44Z"/></svg>`,

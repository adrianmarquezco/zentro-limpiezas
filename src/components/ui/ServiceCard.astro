  castle: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 256 256"><path d="M248,48V96a8,8,0,0,1-8,8H224V216a8,8,0,0,1-8,8H40a8,8,0,0,1-8-8V104H16a8,8,0,0,1-8-8V48a8,8,0,0,1,8-8H56a8,8,0,0,1,8,8V72H96V48a8,8,0,0,1,8-8h48a8,8,0,0,1,8,8V72h32V48a8,8,0,0,1,8-8h40A8,8,0,0,1,248,48ZM160,208V176a32,32,0,0,0-64,0v32ZM112,176a16,16,0,0,1,32,0v32H112Z"/></svg>`,
};

const svgIcon = icons[servicio.icono] ?? icons.house;
---

<a
  href={href}
  class="svc-card group relative rounded-2xl border border-line bg-white overflow-hidden p-5 flex flex-col gap-4 hover:-translate-y-1 transition-all duration-200"
  style="box-shadow: 0 1px 3px rgba(10,37,64,0.06)"
  data-reveal
>
  <!-- Barra de acento superior -->
  <span aria-hidden="true" class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-accent via-accent/70 to-accent/20 opacity-60 group-hover:opacity-100 transition-opacity duration-200"></span>

  <div class="w-11 h-11 rounded-xl bg-primary/5 flex items-center justify-center text-primary group-hover:bg-accent group-hover:text-white transition-all duration-200 shrink-0">
    <Fragment set:html={svgIcon} />
  </div>

  <div class="flex-1">
    <h3 class="font-serif text-lg text-primary leading-snug mb-2">{nombre}</h3>
    <p class="text-mid text-sm leading-relaxed">{servicio.descripcionCorta}</p>
  </div>

  <div class="flex items-center justify-between pt-3 border-t border-line">
    <span class="text-xs text-mid bg-warm px-2.5 py-1 rounded-full">
      {servicio.precioDesde ? `desde ${servicio.precioDesde}` : (lang === 'gl' ? 'Presuposto' : 'Presupuesto')}
    </span>
    <span class="flex items-center gap-1 text-sm font-medium text-primary/40 group-hover:text-accent transition-colors">
      {lang === 'gl' ? 'Ver' : 'Ver'}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </span>
  </div>
</a>

<style>
.svc-card {
  transition: transform 0.2s cubic-bezier(0.16,1,0.3,1),
              box-shadow 0.2s cubic-bezier(0.16,1,0.3,1);
}
@media (hover: hover) {
  .svc-card:hover {
    box-shadow: 0 12px 40px -8px rgba(0,196,140,0.22), 0 4px 16px -4px rgba(10,37,64,0.12);
  }
}
</style>

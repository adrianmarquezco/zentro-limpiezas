  'buildings-alt': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 256 256"><path d="M240,208H224V96a16,16,0,0,0-16-16H168V48a16,16,0,0,0-16-16H56A16,16,0,0,0,40,48V208H24a8,8,0,0,0,0,16H240a8,8,0,0,0,0-16ZM208,96V208H168V96ZM56,48H152V208H56ZM72,88h64a8,8,0,0,0,0-16H72a8,8,0,0,0,0,16Zm0,40h64a8,8,0,0,0,0-16H72a8,8,0,0,0,0,16Zm0,40h64a8,8,0,0,0,0-16H72a8,8,0,0,0,0,16Z"/></svg>`,

---
import { BUSINESS, buildWhatsAppUrl, WA_MESSAGES } from '@/data/config';
interface Props { message?: string; lang?: 'es' | 'gl'; }
const { message = WA_MESSAGES.default, lang = 'es' } = Astro.props;
const isGL = lang === 'gl';
const waUrl = buildWhatsAppUrl(message);
---

<!-- Barra CTA sticky — solo mobile, aparece al hacer scroll -->
<div
  id="cta-bar"
  class="fixed bottom-0 left-0 right-0 z-40 md:hidden translate-y-full transition-transform duration-300"
  style="padding-bottom: env(safe-area-inset-bottom, 0)"
>
  <div class="bg-primary/95 backdrop-blur-sm border-t border-white/10">
    <p class="text-center text-[10px] text-white/35 font-semibold uppercase tracking-widest py-1.5 border-b border-white/10">
      {isGL ? 'Orzamento gratuíto · Respondemos en 24h' : 'Presupuesto gratuito · Respondemos en 24h'}
    </p>
  <div class="px-3 py-2.5 grid grid-cols-3 gap-2">
    <a href={BUSINESS.phoneHref} class="flex flex-col items-center gap-0.5 text-white/80 hover:text-white text-xs font-medium">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.65 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      {isGL ? 'Chamar' : 'Llamar'}
    </a>
    <a
      href={waUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex flex-col items-center gap-0.5 text-success text-xs font-semibold"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>
    <a href={isGL ? '/gl/orzamento/' : '/presupuesto/'} class="flex flex-col items-center gap-0.5 text-accent text-xs font-semibold">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
      </svg>
      {isGL ? 'Orzamento' : 'Presupuesto'}
    </a>
  </div>
  </div>
</div>

<script>
const bar = document.getElementById('cta-bar');
window.addEventListener('scroll', () => {
  if (window.scrollY > 300) bar?.classList.remove('translate-y-full');
  else bar?.classList.add('translate-y-full');
}, { passive: true });
</script>

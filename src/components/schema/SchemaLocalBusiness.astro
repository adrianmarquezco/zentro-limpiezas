---
const schema = {
  '@context': 'https://schema.org',
  '@type': 'CleaningService',
  '@id': 'https://zentrolimpiezas.es/#business',
  name: 'Zentro Limpiezas',
  image: 'https://zentrolimpiezas.es/images/logo.webp',
  logo: 'https://zentrolimpiezas.es/images/logo.webp',
  telephone: '+34616054001',
  url: 'https://zentrolimpiezas.es',
  priceRange: '€€',
  foundingDate: '2004',
  paymentAccepted: 'Cash, Bizum, Bank Transfer',
  currenciesAccepted: 'EUR',
  description: 'Servicio profesional de limpieza de viviendas, oficinas, locales, cristales, comunidades, pazos y apartamentos turísticos en Ferrol, A Coruña y toda Ferrolterra. Productos ecológicos incluidos en el precio. Más de 20 años de experiencia.',
  sameAs: [
    'https://zentrolimpiezas.es',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Ferrol',
    addressRegion: 'A Coruña',
    addressCountry: 'ES',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 43.4833, longitude: -8.2333 },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'], opens: '08:00', closes: '14:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday'], opens: '09:00', closes: '14:00' },
  ],
  areaServed: [
    'Ferrol','A Coruña','Narón','Neda','Fene','Mugardos','Valdoviño','Ares',
    'Moeche','San Sadurniño','Cabanas','Pontedeume','Cedeira','Ortigueira','Cerdido',
    'Culleredo','Arteixo','Cambre','Oleiros','Sada','Bergondo','Abegondo',
    'Carral','Betanzos','Paderne','Oza-Cesuras','Coirós','Irixoa','Vilarmaior',
  ].map(n => ({ '@type': 'City', name: n })),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de limpieza ecológica',
    itemListElement: [
      'Limpieza de viviendas','Limpieza de pisos','Limpieza de oficinas',
      'Limpieza fin de obra','Limpieza de comunidades','Limpieza de cristales',
      'Limpieza de pazos y eventos','Limpieza de apartamentos turísticos','Limpieza periódica',
    ].map(n => ({ '@type': 'Offer', itemOffered: { '@type': 'Service', name: n } })),
  },
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />

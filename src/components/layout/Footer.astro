---
import { BUSINESS } from '@/data/config';
interface Props { lang?: 'es' | 'gl'; }
const { lang = 'es' } = Astro.props;
const isGL = lang === 'gl';
const base = isGL ? '/gl' : '';
const year = new Date().getFullYear();
---

<footer class="bg-primary text-white/70 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Columna 1: Marca -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-9 h-9 bg-accent rounded-xl flex items-center justify-center flex-shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <span class="font-display text-lg text-white">Zentro Limpiezas</span>
        </div>
        <p class="text-sm leading-relaxed mb-5">
          {isGL
            ? 'Limpeza profesional en Ferrolterra e Área Metropolitana de A Coruña. Produtos ecolóxicos sempre incluídos.'
            : 'Limpieza profesional en Ferrolterra y el Área Metropolitana de A Coruña. Productos ecológicos siempre incluidos.'}
        </p>
        <div class="space-y-2 text-sm">
          <a href={BUSINESS.phoneHref} class="flex items-center gap-2 text-white/70 hover:text-white transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.65 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {BUSINESS.phoneDisplay}
          </a>
          <a href={`${BUSINESS.whatsappBase}?text=Hola%2C+me+gustar%C3%ADa+pedir+presupuesto`} target="_blank" rel="noopener" class="flex items-center gap-2 text-white/70 hover:text-white transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
        <!-- Lang switcher -->
        <div class="mt-4 flex gap-2 text-xs">
          <a href="/" class={`px-2.5 py-1 rounded-full border transition-colors ${!isGL ? 'border-accent text-accent' : 'border-white/20 text-white/70 hover:border-white/50'}`}>ES</a>
          <a href="/gl/" class={`px-2.5 py-1 rounded-full border transition-colors ${isGL ? 'border-accent text-accent' : 'border-white/20 text-white/70 hover:border-white/50'}`}>GL</a>
        </div>
      </div>

      <!-- Columna 2: Servicios -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">{isGL ? 'Servizos' : 'Servicios'}</h3>
        <ul class="space-y-2 text-sm">
          {[
            ['limpieza-de-viviendas','limpeza-de-vivendas', isGL ? 'Limpeza de vivendas' : 'Limpieza de viviendas'],
            ['limpieza-de-oficinas','limpeza-de-oficinas', isGL ? 'Limpeza de oficinas' : 'Limpieza de oficinas'],
            ['limpieza-fin-de-obra','limpeza-fin-de-obra', isGL ? 'Limpeza fin de obra' : 'Limpieza fin de obra'],
            ['limpieza-a-fondo','limpeza-a-fondo', isGL ? 'Limpeza a fondo' : 'Limpieza a fondo'],
            ['limpieza-de-cristales','limpeza-de-cristais', isGL ? 'Limpeza de cristais' : 'Limpieza de cristales'],
            ['limpieza-de-comunidades','limpeza-de-comunidades', isGL ? 'Limpeza de comunidades' : 'Limpieza de comunidades'],
            ['limpieza-de-pazos-y-eventos','limpeza-de-pazos', isGL ? 'Limpeza de pazos' : 'Limpieza de pazos'],
            ['limpieza-de-apartamentos-turisticos','limpeza-de-apartamentos', isGL ? 'Apartamentos turísticos' : 'Apartamentos turísticos'],
          ].map(([slugES, slugGL, label]) => (
            <li>
              <a href={isGL ? `/gl/servizos/${slugGL}/` : `/servicios/${slugES}/`} class="text-white/70 hover:text-white transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 3: Ferrolterra -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Ferrolterra</h3>
        <ul class="space-y-2 text-sm">
          {['ferrol','naron','neda','fene','mugardos','valdovino','ares','pontedeume','cedeira','ortigueira'].map(slug => (
            <li>
              <a href={isGL ? `/gl/zonas/${slug}/` : `/zonas/${slug}/`} class="text-white/70 hover:text-white transition-colors capitalize">{slug.replace(/-/g,' ')}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 4: Área A Coruña + Legal -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">{isGL ? 'Área Coruña' : 'Área A Coruña'}</h3>
        <ul class="space-y-2 text-sm">
          {['a-coruna','culleredo','arteixo','cambre','oleiros','sada','bergondo','betanzos','abegondo','carral'].map(slug => (
            <li>
              <a href={isGL ? `/gl/zonas/${slug}/` : `/zonas/${slug}/`} class="text-white/70 hover:text-white transition-colors capitalize">{slug.replace(/-/g,' ').replace('a coruna','A Coruña')}</a>
            </li>
          ))}
        </ul>
        <div class="mt-6">
          <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">{isGL ? 'A empresa' : 'La empresa'}</h3>
          <ul class="space-y-2 text-sm">
            <li><a href={isGL ? '/gl/sobre-nos/' : '/sobre-nosotros/'} class="text-white/70 hover:text-white transition-colors">{isGL ? 'Sobre nós' : 'Sobre nosotros'}</a></li>
            <li><a href={isGL ? '/gl/orzamento/' : '/presupuesto/'} class="text-white/70 hover:text-white transition-colors">{isGL ? 'Pedir orzamento' : 'Pedir presupuesto'}</a></li>
            <li><a href="/legal/aviso-legal/" class="text-white/70 hover:text-white transition-colors">{isGL ? 'Aviso Legal' : 'Aviso Legal'}</a></li>
            <li><a href="/legal/politica-privacidad/" class="text-white/70 hover:text-white transition-colors">{isGL ? 'Privacidade' : 'Privacidad'}</a></li>
            <li><a href="/legal/cookies/" class="text-white/70 hover:text-white transition-colors">Cookies</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/40">
      <p>© {year} Zentro Limpiezas. {isGL ? 'Todos os dereitos reservados.' : 'Todos los derechos reservados.'}</p>
      <p class="flex items-center gap-1.5">
        <span class="badge-eco text-xs py-0.5 flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
          {isGL ? 'Ecolóxico' : 'Ecológico'}
        </span>
        {isGL ? 'Ferrolterra · A Coruña' : 'Ferrolterra · A Coruña'}
      </p>
    </div>
  </div>
</footer>

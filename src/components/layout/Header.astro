---
import { BUSINESS, buildWhatsAppUrl, WA_MESSAGES } from '@/data/config';

interface Props {
  lang?: 'es' | 'gl';
}
const { lang = 'es' } = Astro.props;
const isGL = lang === 'gl';
const base = isGL ? '/gl' : '';
const waUrl = buildWhatsAppUrl(WA_MESSAGES.default);
---

<header class="header fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="site-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href={isGL ? '/gl/' : '/'} class="flex items-center gap-2.5 group flex-shrink-0">
        <div class="w-9 h-9 bg-accent rounded-xl flex items-center justify-center transition-transform group-hover:scale-105">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <span class="font-display text-lg text-white font-normal leading-tight">
          Zentro<br/><span class="text-accent text-sm">Limpiezas</span>
        </span>
      </a>

      <!-- Nav desktop -->
      <nav class="hidden lg:flex items-center gap-7 text-sm font-medium text-white/80">
        <a href={isGL ? '/gl/servizos/' : '/servicios/'} class="hover:text-white transition-colors">{isGL ? 'Servizos' : 'Servicios'}</a>
        <a href={isGL ? '/gl/zonas/' : '/zonas/'} class="hover:text-white transition-colors">Zonas</a>
        <a href={isGL ? '/gl/sobre-nos/' : '/sobre-nosotros/'} class="hover:text-white transition-colors">{isGL ? 'Sobre nós' : 'Sobre nosotros'}</a>
        <a href={isGL ? '/gl/blog/' : '/blog/'} class="hover:text-white transition-colors">Blog</a>
      </nav>

      <!-- CTAs desktop -->
      <div class="hidden lg:flex items-center gap-3">
        <a href={BUSINESS.phoneHref} class="flex items-center gap-2 text-white/80 hover:text-white text-sm font-medium transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.65 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {BUSINESS.phoneDisplay}
        </a>
        <a href={isGL ? '/gl/orzamento/' : '/presupuesto/'} class="btn-accent text-sm px-5 py-2.5">
          {isGL ? 'Pedir orzamento' : 'Pedir presupuesto'}
        </a>
      </div>

      <!-- Burger mobile -->
      <button
        id="menu-toggle"
        class="lg:hidden flex flex-col gap-1.5 p-2 text-white"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <span class="w-6 h-0.5 bg-current transition-all duration-200 origin-center" id="b1"></span>
        <span class="w-6 h-0.5 bg-current transition-all duration-200" id="b2"></span>
        <span class="w-6 h-0.5 bg-current transition-all duration-200 origin-center" id="b3"></span>
      </button>
    </div>
  </div>

  <!-- Menú mobile -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-primary border-t border-white/10 px-4 py-6 space-y-4"
  >
    <nav class="space-y-3">
      <a href={isGL ? '/gl/servizos/' : '/servicios/'} class="block text-white/80 hover:text-white text-base font-medium py-1 transition-colors">{isGL ? 'Servizos' : 'Servicios'}</a>
      <a href={isGL ? '/gl/zonas/' : '/zonas/'} class="block text-white/80 hover:text-white text-base font-medium py-1 transition-colors">Zonas</a>
      <a href={isGL ? '/gl/sobre-nos/' : '/sobre-nosotros/'} class="block text-white/80 hover:text-white text-base font-medium py-1 transition-colors">{isGL ? 'Sobre nós' : 'Sobre nosotros'}</a>
      <a href={isGL ? '/gl/blog/' : '/blog/'} class="block text-white/80 hover:text-white text-base font-medium py-1 transition-colors">Blog</a>
    </nav>
    <div class="pt-2 border-t border-white/10 space-y-3">
      <a href={BUSINESS.phoneHref} class="btn-whatsapp w-full justify-center py-3">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.65 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {BUSINESS.phoneDisplay}
      </a>
      <a href={isGL ? '/gl/orzamento/' : '/presupuesto/'} class="btn-accent w-full justify-center py-3">
        {isGL ? 'Pedir orzamento' : 'Pedir presupuesto'}
      </a>
    </div>
  </div>
</header>

<script>
const toggle = document.getElementById('menu-toggle');
const menu   = document.getElementById('mobile-menu');
const b1 = document.getElementById('b1');
const b2 = document.getElementById('b2');
const b3 = document.getElementById('b3');

toggle?.addEventListener('click', () => {
  const open = menu?.classList.toggle('hidden') === false;
  toggle.setAttribute('aria-expanded', String(open));
  if (open) {
    b1?.classList.add('rotate-45', 'translate-y-2');
    b2?.classList.add('opacity-0');
    b3?.classList.add('-rotate-45', '-translate-y-2');
  } else {
    b1?.classList.remove('rotate-45', 'translate-y-2');
    b2?.classList.remove('opacity-0');
    b3?.classList.remove('-rotate-45', '-translate-y-2');
  }
});
</script>

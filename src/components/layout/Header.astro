---
import { BUSINESS, buildWhatsAppUrl, WA_MESSAGES } from '@/data/config';
import { SERVICIOS } from '@/data/servicios';

interface Props {
  lang?: 'es' | 'gl';
}
const { lang = 'es' } = Astro.props;
const isGL = lang === 'gl';
const base = isGL ? '/gl' : '';
const waUrl = buildWhatsAppUrl(WA_MESSAGES.default);
const path = Astro.url.pathname;

const municipiosNav: Record<string, string> = {
  'ferrol':'Ferrol','naron':'Narón','neda':'Neda','fene':'Fene','mugardos':'Mugardos',
  'valdovino':'Valdoviño','ares':'Ares','pontedeume':'Pontedeume','cedeira':'Cedeira',
  'ortigueira':'Ortigueira','moeche':'Moeche','san-sadurnino':'San Sadurniño',
  'cabanas':'Cabanas','cerdido':'Cerdido','a-coruna':'A Coruña','culleredo':'Culleredo',
  'arteixo':'Arteixo','cambre':'Cambre','oleiros':'Oleiros','sada':'Sada',
  'bergondo':'Bergondo','betanzos':'Betanzos','abegondo':'Abegondo','carral':'Carral',
  'paderne':'Paderne','oza-cesuras':'Oza-Cesuras','coiros':'Coirós',
  'irixoa':'Irixoa','vilarmaior':'Vilarmaior',
};

const serviciosNav = SERVICIOS.filter(s => s.tier === 1);
---

<header class="header fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="site-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href={isGL ? '/gl/' : '/'} class="flex-shrink-0 group" aria-label="Zentro Limpiezas — inicio">
        <img
          src="/images/logo.png"
          alt="Zentro Limpiezas"
          class="h-12 w-auto transition-opacity group-hover:opacity-80 brightness-0 invert"
          width="160"
          height="40"
          loading="eager"
          fetchpriority="high"
        />
      </a>

      <!-- Nav desktop -->
      <nav class="hidden lg:flex items-center gap-6 text-sm font-medium text-white/80">

        <!-- Servicios mega-menu -->
        <div class="relative group/svc">
          <a href={isGL ? '/gl/servizos/' : '/servicios/'}
            class={`flex items-center gap-1 py-2 transition-colors ${path.startsWith('/servicios') ? 'text-white' : 'hover:text-white'}`}>
            {isGL ? 'Servizos' : 'Servicios'}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover/svc:rotate-180 transition-transform duration-200"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
          <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible opacity-0 group-hover/svc:visible group-hover/svc:opacity-100 transition-all duration-200 z-50">
            <div class="bg-white rounded-2xl shadow-2xl border border-line p-5 w-[480px]">
              <div class="grid grid-cols-2 gap-1 mb-4">
                {serviciosNav.map(s => (
                  <a href={`${base}/${isGL ? 'servizos' : 'servicios'}/${isGL ? s.slugGL : s.slug}/`}
                    class="flex items-start gap-2.5 p-2.5 rounded-xl hover:bg-warm transition-colors group/item">
                    <span class="text-accent mt-0.5 text-xs shrink-0">→</span>
                    <div>
                      <p class="font-semibold text-primary text-xs leading-snug group-hover/item:text-accent transition-colors">{isGL ? s.nombreGL : s.nombre}</p>
                      {s.precioDesde && <p class="text-mid text-[10px] mt-0.5">desde {s.precioDesde}</p>}
                    </div>
                  </a>
                ))}
              </div>
              <div class="border-t border-line pt-3">
                <a href={`${base}/${isGL ? 'servizos' : 'servicios'}/`} class="text-accent text-xs font-semibold hover:underline">
                  {isGL ? 'Ver todos os servizos →' : 'Ver todos los servicios →'}
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Zonas mega-menu -->
        <div class="relative group/zona">
          <a href={isGL ? '/gl/zonas/' : '/zonas/'}
            class={`flex items-center gap-1 py-2 transition-colors ${path.startsWith('/zonas') ? 'text-white' : 'hover:text-white'}`}>
            Zonas
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover/zona:rotate-180 transition-transform duration-200"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
          <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible opacity-0 group-hover/zona:visible group-hover/zona:opacity-100 transition-all duration-200 z-50">
            <div class="bg-white rounded-2xl shadow-2xl border border-line p-5 w-[440px]">
              <div class="grid grid-cols-2 gap-x-8 gap-y-0">
                <div>
                  <p class="text-[10px] font-bold text-primary uppercase tracking-widest mb-2">Ferrolterra</p>
                  {['ferrol','naron','neda','fene','cedeira','pontedeume','ares','mugardos','valdovino','ortigueira'].map(slug => (
                    <a href={`${base}/zonas/${slug}/`} class="block text-xs text-charcoal hover:text-accent py-1 transition-colors">{municipiosNav[slug]}</a>
                  ))}
                </div>
                <div>
                  <p class="text-[10px] font-bold text-primary uppercase tracking-widest mb-2">Área A Coruña</p>
                  {['a-coruna','culleredo','arteixo','cambre','oleiros','sada','betanzos','bergondo','carral','abegondo'].map(slug => (
                    <a href={`${base}/zonas/${slug}/`} class="block text-xs text-charcoal hover:text-accent py-1 transition-colors">{municipiosNav[slug]}</a>
                  ))}
                </div>
              </div>
              <div class="border-t border-line pt-3 mt-3">
                <a href={`${base}/zonas/`} class="text-accent text-xs font-semibold hover:underline">
                  {isGL ? 'Ver todos os concellos →' : 'Ver todos los municipios →'}
                </a>
              </div>
            </div>
          </div>
        </div>

        <a href={isGL ? '/gl/sobre-nos/' : '/sobre-nosotros/'}
          class={`py-2 transition-colors ${path.startsWith('/sobre-nosotros') ? 'text-white' : 'hover:text-white'}`}>
          {isGL ? 'Sobre nós' : 'Sobre nosotros'}
        </a>
        <a href={isGL ? '/gl/blog/' : '/blog/'}
          class={`py-2 transition-colors ${path.startsWith('/blog') ? 'text-white' : 'hover:text-white'}`}>
          Blog
        </a>
      </nav>

      <!-- CTAs desktop -->
      <div class="hidden lg:flex items-center gap-3">
        <a href={BUSINESS.phoneHref} class="flex items-center gap-2 text-white/80 hover:text-white text-sm font-medium transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.65 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {BUSINESS.phoneDisplay}
        </a>
        <a href={isGL ? '/gl/orzamento/' : '/presupuesto/'} class="btn-accent text-sm px-5 py-2.5">
          {isGL ? 'Pedir orzamento' : 'Pedir presupuesto'}
        </a>
      </div>

      <!-- Burger mobile -->
      <button
        id="menu-toggle"
        class="lg:hidden flex flex-col gap-1.5 p-2 text-white"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <span class="w-6 h-0.5 bg-current transition-all duration-200 origin-center" id="b1"></span>
        <span class="w-6 h-0.5 bg-current transition-all duration-200" id="b2"></span>
        <span class="w-6 h-0.5 bg-current transition-all duration-200 origin-center" id="b3"></span>
      </button>
    </div>
  </div>

  <!-- Menú mobile -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-primary border-t border-white/10 px-4 py-5 space-y-1 max-h-[calc(100vh-4rem)] overflow-y-auto"
  >
    <nav>
      <!-- Servicios expandible -->
      <div>
        <button
          id="mob-servicios-btn"
          class="w-full flex items-center justify-between text-white/80 hover:text-white text-base font-medium py-3 transition-colors"
          aria-expanded="false"
        >
          <span>{isGL ? 'Servizos' : 'Servicios'}</span>
          <svg id="mob-servicios-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div id="mob-servicios-sub" class="hidden pl-3 pb-2 space-y-1 border-l border-white/10">
          <a href={`${base}/servicios/`} class="block text-accent text-sm font-semibold py-1.5 hover:underline">{isGL ? 'Ver todos os servizos →' : 'Ver todos los servicios →'}</a>
          {[
            { slug: isGL ? 'limpeza-de-vivendas' : 'limpieza-de-viviendas',   label: isGL ? 'Limpeza de vivendas'   : 'Limpieza de viviendas' },
            { slug: isGL ? 'limpeza-de-oficinas' : 'limpieza-de-oficinas',    label: isGL ? 'Limpeza de oficinas'   : 'Limpieza de oficinas' },
            { slug: isGL ? 'limpeza-fin-de-obra' : 'limpieza-fin-de-obra',    label: isGL ? 'Limpeza fin de obra'   : 'Limpieza fin de obra' },
            { slug: isGL ? 'limpeza-periodica'   : 'limpieza-periodica',      label: isGL ? 'Limpeza periódica'     : 'Limpieza periódica' },
            { slug: isGL ? 'limpeza-a-fondo'     : 'limpieza-a-fondo',        label: isGL ? 'Limpeza a fondo'       : 'Limpieza a fondo' },
          ].map(item => (
            <a href={`${base}/${isGL ? 'servizos' : 'servicios'}/${item.slug}/`} class="block text-white/60 hover:text-white text-sm py-1.5 transition-colors">
              {item.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Zonas expandible -->
      <div>
        <button
          id="mob-zonas-btn"
          class="w-full flex items-center justify-between text-white/80 hover:text-white text-base font-medium py-3 transition-colors"
          aria-expanded="false"
        >
          <span>Zonas</span>
          <svg id="mob-zonas-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div id="mob-zonas-sub" class="hidden pl-3 pb-2 space-y-1 border-l border-white/10">
          <a href={`${base}/zonas/`} class="block text-accent text-sm font-semibold py-1.5 hover:underline">{isGL ? 'Ver todos os concellos →' : 'Ver todos los municipios →'}</a>
          {[
            { slug: 'ferrol',      label: 'Ferrol' },
            { slug: 'naron',       label: 'Narón' },
            { slug: 'a-coruna',    label: 'A Coruña' },
            { slug: 'arteixo',     label: 'Arteixo' },
            { slug: 'culleredo',   label: 'Culleredo' },
            { slug: 'pontedeume',  label: 'Pontedeume' },
          ].map(item => (
            <a href={`${base}/zonas/${item.slug}/`} class="block text-white/60 hover:text-white text-sm py-1.5 transition-colors">
              {item.label}
            </a>
          ))}
        </div>
      </div>

      <a href={isGL ? '/gl/sobre-nos/' : '/sobre-nosotros/'} class="block text-white/80 hover:text-white text-base font-medium py-3 transition-colors">{isGL ? 'Sobre nós' : 'Sobre nosotros'}</a>
      <a href={isGL ? '/gl/blog/' : '/blog/'} class="block text-white/80 hover:text-white text-base font-medium py-3 transition-colors">Blog</a>
    </nav>

    <div class="pt-3 border-t border-white/10 space-y-3">
      <a href={BUSINESS.phoneHref} class="btn-whatsapp w-full justify-center py-3">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.65 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {BUSINESS.phoneDisplay}
      </a>
      <a href={isGL ? '/gl/orzamento/' : '/presupuesto/'} class="btn-accent w-full justify-center py-3">
        {isGL ? 'Pedir orzamento' : 'Pedir presupuesto'}
      </a>
    </div>
  </div>
</header>

<script>
const toggle = document.getElementById('menu-toggle');
const menu   = document.getElementById('mobile-menu');
const b1 = document.getElementById('b1');
const b2 = document.getElementById('b2');
const b3 = document.getElementById('b3');

toggle?.addEventListener('click', () => {
  const open = menu?.classList.toggle('hidden') === false;
  toggle.setAttribute('aria-expanded', String(open));
  document.body.style.overflow = open ? 'hidden' : '';
  if (open) {
    b1?.classList.add('rotate-45', 'translate-y-2');
    b2?.classList.add('opacity-0');
    b3?.classList.add('-rotate-45', '-translate-y-2');
  } else {
    b1?.classList.remove('rotate-45', 'translate-y-2');
    b2?.classList.remove('opacity-0');
    b3?.classList.remove('-rotate-45', '-translate-y-2');
  }
});

function setupSubmenu(btnId: string, subId: string, iconId: string) {
  const btn  = document.getElementById(btnId);
  const sub  = document.getElementById(subId);
  const icon = document.getElementById(iconId);
  btn?.addEventListener('click', () => {
    const open = sub?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
    icon?.classList.toggle('rotate-180', open);
  });
}

setupSubmenu('mob-servicios-btn', 'mob-servicios-sub', 'mob-servicios-icon');
setupSubmenu('mob-zonas-btn',     'mob-zonas-sub',     'mob-zonas-icon');
</script>

---
import ServiceCard from '@/components/ui/ServiceCard.astro';
import { SERVICIOS } from '@/data/servicios';

interface Props {
  lang?: 'es' | 'gl';
  title?: string;
}
const { lang = 'es', title } = Astro.props;
const defaultTitle = lang === 'gl' ? 'Os nosos servizos' : 'Nuestros servicios';
---

<section class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-serif text-3xl lg:text-4xl text-warm mb-12 text-center" data-reveal>
      {title ?? defaultTitle}
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {SERVICIOS.map((s) => (
        <ServiceCard servicio={s} lang={lang} />
      ))}
    </div>
  </div>
</section>

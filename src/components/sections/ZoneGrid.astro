---
import ZoneCard from '@/components/ui/ZoneCard.astro';
import { MUNICIPIOS, MUNICIPIOS_FERROLTERRA, MUNICIPIOS_CORUNA } from '@/data/municipios';

interface Props {
  lang?: 'es' | 'gl';
  variant?: 'all' | 'ferrolterra' | 'coruna';
  title?: string;
  showHeading?: boolean;
}
const { lang = 'es', variant = 'all', title, showHeading = true } = Astro.props;
const muns = variant === 'ferrolterra'
  ? MUNICIPIOS_FERROLTERRA
  : variant === 'coruna'
    ? MUNICIPIOS_CORUNA
    : MUNICIPIOS;

const defaultTitle = lang === 'gl' ? 'Servizo de limpeza nos municipios de Ferrolterra e A Coruña' : 'Servicio de limpieza en los municipios de Ferrolterra y A Coruña';
---

<section class="py-20 lg:py-28 bg-charcoal">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {showHeading && (
      <h2 class="font-display text-3xl lg:text-4xl text-warm mb-4 text-center" data-reveal>
        {title ?? defaultTitle}
      </h2>
    )}
    <p class="text-white/60 text-center mb-12 max-w-xl mx-auto" data-reveal>
      {lang === 'gl'
        ? 'Cubrimos Ferrol, A Coruña e toda a súa área metropolitana e comarcas próximas.'
        : 'Cubrimos Ferrol, A Coruña y toda su área metropolitana y comarcas próximas.'}
    </p>

    {variant === 'all' && (
      <div class="mb-10">
        <p class="text-white/40 text-xs uppercase tracking-widest mb-4 font-semibold" data-reveal>
          {lang === 'gl' ? 'Limpeza en Ferrolterra' : 'Limpieza en Ferrolterra'}
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 mb-8">
          {MUNICIPIOS_FERROLTERRA.map((m) => <ZoneCard municipio={m} lang={lang} />)}
        </div>
        <p class="text-white/40 text-xs uppercase tracking-widest mb-4 font-semibold" data-reveal>
          {lang === 'gl' ? 'Limpeza na Área Metropolitana de A Coruña' : 'Limpieza en el Área Metropolitana de A Coruña'}
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
          {MUNICIPIOS_CORUNA.map((m) => <ZoneCard municipio={m} lang={lang} />)}
        </div>
      </div>
    )}

    {variant !== 'all' && (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
        {muns.map((m) => <ZoneCard municipio={m} lang={lang} />)}
      </div>
    )}
  </div>
</section>

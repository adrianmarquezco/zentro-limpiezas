---
import { BUSINESS, buildWhatsAppUrl, WA_MESSAGES } from '@/data/config';

interface Props {
  servicio: string;
  eyebrow: string;
  h1: string;
  subtitle: string;
  precioDesde?: string | null;
  lang?: 'es' | 'gl';
}
const { servicio, eyebrow, h1, subtitle, precioDesde, lang = 'es' } = Astro.props;
const waUrl = buildWhatsAppUrl(WA_MESSAGES.servicio(servicio));
const presupuestoHref = lang === 'gl' ? '/gl/orzamento/' : '/presupuesto/';
---

<section class="hero-section relative bg-primary overflow-hidden py-24 lg:py-32">
  <div class="noise-overlay" />
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <span class="hero-eyebrow inline-block bg-accent/10 text-accent border border-accent/30 rounded-full px-4 py-1 text-sm font-medium mb-6">
        {eyebrow}
      </span>
      <h1 class="hero-h1-line1 font-serif text-4xl sm:text-5xl lg:text-6xl text-warm leading-tight" set:html={h1} />
      {precioDesde && (
        <p class="mt-4 font-mono text-accent text-xl">desde <span class="text-3xl font-bold">{precioDesde}</span></p>
      )}
      <p class="hero-subtitle text-white/70 text-lg mt-6 max-w-xl leading-relaxed speakable-intro">{subtitle}</p>
      <div class="hero-ctas flex flex-wrap gap-3 mt-8">
        <a href={`tel:${BUSINESS.phoneHref.replace('tel:','')}`} class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256" class="shrink-0">
            <path d="M222.37,158.46l-47.11-21.11-.13-.06a16,16,0,0,0-15.17,1.4,8.12,8.12,0,0,0-.75.56L134.87,160c-15.42-7.49-31.34-23.29-38.83-38.51l20.78-24.71c.2-.25.39-.5.57-.77a16,16,0,0,0,1.32-15.06l0-.12L97.54,33.64a16,16,0,0,0-16.62-9.52A56.26,56.26,0,0,0,32,80c0,79.4,64.6,144,144,144a56.26,56.26,0,0,0,55.88-48.92A16,16,0,0,0,222.37,158.46Z"/>
          </svg>
          {BUSINESS.phoneDisplay}
        </a>
        <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
            <path d="M187.58,144.84l-32-16a8,8,0,0,0-8,.5l-14.69,9.8a40.55,40.55,0,0,1-16-16l9.8-14.69a8,8,0,0,0,.5-8l-16-32A8,8,0,0,0,104,64a40,40,0,0,0-40,40,88.1,88.1,0,0,0,88,88,40,40,0,0,0,40-40A8,8,0,0,0,187.58,144.84ZM152,176a72.08,72.08,0,0,1-72-72,24,24,0,0,1,19.29-23.54l11.48,23L101,118.18a8,8,0,0,0-.73,7.51,56.47,56.47,0,0,0,30,30,8,8,0,0,0,7.53-.68l14.71-9.8,23,11.48A24,24,0,0,1,152,176ZM128,24A104,104,0,0,0,36.18,176.88L24.83,210.93a16,16,0,0,0,20.24,20.24l34.05-11.35A104,104,0,1,0,128,24Zm0,192a88.11,88.11,0,0,1-45.06-12.34,8,8,0,0,0-6.54-.67L40,216,52.95,179.6a8,8,0,0,0-.66-6.54A88,88,0,1,1,128,216Z"/>
          </svg>
          WhatsApp
        </a>
        <a href={presupuestoHref} class="btn-outline-light">{lang === 'gl' ? 'Orzamento gratis' : 'Presupuesto gratis'}</a>
      </div>
    </div>
  </div>
</section>
